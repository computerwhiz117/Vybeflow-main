# Core app
VYBEFLOW_SECRET_KEY=replace_with_a_long_random_secret
VYBEFLOW_APP_BASE_URL=http://127.0.0.1:5000

# SMTP mail delivery (for real professional VybeFlow email links)
VYBEFLOW_SMTP_HOST=smtp.gmail.com
VYBEFLOW_SMTP_PORT=587
VYBEFLOW_SMTP_USER=your_email@example.com
VYBEFLOW_SMTP_PASS=your_email_app_password
VYBEFLOW_SMTP_USE_TLS=true
VYBEFLOW_SMTP_USE_SSL=false
VYBEFLOW_MAIL_FROM=VybeFlow <your_email@example.com>
PASSWORD_RESET_OVERRIDE_EMAIL=
