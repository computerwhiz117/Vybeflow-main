    };
    const emojiAudioCache = new Map();
    let emojiAudioUnlocked = false;

    function unlockEmojiAudio() {
      if (emojiAudioUnlocked || !audioCtx) return;
      if (audioCtx.state === 'suspended') {
        audioCtx.resume().catch(function () {});
      }
      emojiAudioUnlocked = true;
    }

    document.addEventListener('pointerdown', unlockEmojiAudio, { once: true });

    function playFunnyEmojiSynth(emoji) {
      if (!audioCtx) return;
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
      const key = String(emoji || 'вЬ®');
      const code = key.codePointAt(0) || 10024;
      const now = audioCtx.currentTime;
      const base = 240 + (code % 420);
      const duration = 0.09 + ((code % 5) * 0.018);

      const oscA = audioCtx.createOscillator();
      const oscB = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      const filter = audioCtx.createBiquadFilter();

      const shapes = ['triangle', 'square', 'sine', 'sawtooth'];
      const shape = shapes[code % shapes.length];

      oscA.type = shape;
      oscB.type = code % 2 ? 'triangle' : 'sine';
      oscA.frequency.setValueAtTime(base, now);
      oscA.frequency.exponentialRampToValueAtTime(base * (1.25 + ((code % 7) * 0.05)), now + duration * 0.72);
      oscB.frequency.setValueAtTime(Math.max(80, base / 2), now);
      oscB.frequency.exponentialRampToValueAtTime(Math.max(120, base * 0.86), now + duration);

      filter.type = code % 3 === 0 ? 'bandpass' : 'lowpass';
      filter.frequency.setValueAtTime(1200 + (code % 900), now);
      filter.Q.setValueAtTime(2 + (code % 6), now);

      gain.gain.setValueAtTime(0.0001, now);
      gain.gain.exponentialRampToValueAtTime(0.045 + ((code % 4) * 0.012), now + 0.012);
      gain.gain.exponentialRampToValueAtTime(0.0001, now + duration);

      oscA.connect(filter);
      oscB.connect(filter);
      filter.connect(gain);
      gain.connect(audioCtx.destination);

      oscA.start(now);
      oscB.start(now);
      oscA.stop(now + duration);
      oscB.stop(now + duration + 0.01);
    }

    function playEmojiSound(emoji) {
      const key = String(emoji || 'вЬ®');
      const fileName = emojiSoundFiles[key];
      if (!fileName) {
        playFunnyEmojiSynth(key);
        return;
      }

      let audio = emojiAudioCache.get(fileName);
      if (!audio) {
        audio = new Audio('/static/uploads/emoji-sounds/' + fileName);
        audio.preload = 'auto';
        emojiAudioCache.set(fileName, audio);
      }

      try {
        audio.currentTime = 0;
      } catch (error) {
      }

      audio.play().catch(function () {
        playFunnyEmojiSynth(key);
      });
    }

    window.VybeEmojiSound = playEmojiSound;

    function insertAtCursor(textarea, text) {
      if (!textarea) return;
      const start = textarea.selectionStart || 0;
      const end = textarea.selectionEnd || 0;
      textarea.value = textarea.value.slice(0, start) + text + textarea.value.slice(end);
      const nextPos = start + text.length;
      textarea.selectionStart = nextPos;
      textarea.selectionEnd = nextPos;
      textarea.focus();
    }

    function makeDraggableSticker(sticker) {
      let dragging = false;
      let dragOffsetX = 0;
      let dragOffsetY = 0;

      sticker.addEventListener('pointerdown', function (event) {
        dragging = true;
        sticker.setPointerCapture(event.pointerId);
        const rect = sticker.getBoundingClientRect();
        dragOffsetX = event.clientX - rect.left;
        dragOffsetY = event.clientY - rect.top;
      });

      sticker.addEventListener('pointermove', function (event) {
        if (!dragging || !emojiStage) return;
        const bounds = emojiStage.getBoundingClientRect();
        const maxX = bounds.width - sticker.offsetWidth;
        const maxY = bounds.height - sticker.offsetHeight;
        const nextX = Math.max(0, Math.min(maxX, event.clientX - bounds.left - dragOffsetX));
        const nextY = Math.max(0, Math.min(maxY, event.clientY - bounds.top - dragOffsetY));
        sticker.style.left = nextX + 'px';
        sticker.style.top = nextY + 'px';
      });

      function endDrag(event) {
        if (!dragging) return;
        dragging = false;
        if (event && event.pointerId !== undefined) {
          sticker.releasePointerCapture(event.pointerId);
        }
      }

      sticker.addEventListener('pointerup', endDrag);
      sticker.addEventListener('pointercancel', endDrag);
    }

    function addEmojiSticker(emoji, x, y) {
      if (!emojiStage) return;
      const sticker = document.createElement('span');
      sticker.className = 'emoji-sticker';
      sticker.textContent = emoji;
      sticker.style.left = (x || 10) + 'px';
      sticker.style.top = (y || 10) + 'px';
      sticker.addEventListener('mouseenter', function () { playEmojiSound(emoji); });
      sticker.addEventListener('pointerdown', function () {
        playEmojiSound(emoji);
        sticker.animate([
          { transform: 'translateY(0) scale(1)' },
          { transform: 'translateY(-4px) scale(1.2)' },
          { transform: 'translateY(0) scale(1)' }
        ], { duration: 200, easing: 'ease-out' });
      });
      sticker.addEventListener('click', function () { playEmojiSound(emoji); });
      makeDraggableSticker(sticker);
      emojiStage.appendChild(sticker);
      playEmojiSound(emoji);
    }

    function addStickerFromTray(emoji) {
      if (!emojiStage) return;
      const rect = emojiStage.getBoundingClientRect();
      const x = Math.max(0, (rect.width / 2) - 16);
      const y = Math.max(0, (rect.height / 2) - 16);
      addEmojiSticker(emoji, x, y);
    }

    function buildRichEmojiRow() {
      if (!emojiRow) return;
      
      function getEmotion(emoji) {
        const cryingEmojis = ['рЯШ≠', 'рЯШҐ', 'рЯ•Ї', 'рЯШњ', 'рЯШЮ'];
        const laughingEmojis = ['рЯШВ', 'рЯШЖ', 'рЯ§£', 'рЯШЬ', 'рЯ§™'];
        const fireEmojis = ['рЯФ•'];
        const shockedEmojis = ['рЯШ±', 'рЯШ≤', 'рЯШѓ'];
        
        if (cryingEmojis.includes(emoji)) return 'crying';
        if (laughingEmojis.includes(emoji)) return 'laughing';
        if (fireEmojis.includes(emoji)) return 'fire';
        if (shockedEmojis.includes(emoji)) return 'shocked';
        return null;
      }
      
      emojiRow.innerHTML = '';
      richEmojis.forEach(function (emoji, index) {
        const emotion = getEmotion(emoji);
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'emoji-btn emoji-rich';
        button.draggable = true;
        button.style.animationDelay = (index % 8) * 0.08 + 's';
        button.textContent = emoji;
        if (emotion) {
          button.setAttribute('data-emotion', emotion);
        }

        button.addEventListener('mouseenter', function () {
          playEmojiSound(emoji);
        });
        button.addEventListener('pointerdown', function () {
          playEmojiSound(emoji);
          button.animate(
            [
              { transform: 'scale(1)' },
              { transform: 'scale(1.18)' },
              { transform: 'scale(1)' }
            ],
            { duration: 200, easing: 'ease-out' }
          );
        });

        button.addEventListener('mousemove', function () {
          button.style.transform = 'scale(1.15)';
        });

        button.addEventListener('mouseleave', function () {
          button.style.transform = '';
        });

        button.addEventListener('click', function () {
          insertAtCursor(postText, emoji + ' ');
          playEmojiSound(emoji);
        });

        button.addEventListener('dragstart', function (event) {
          event.dataTransfer.setData('text/plain', emoji);
        });

        emojiRow.appendChild(button);
      });
    }

    function renderStickerGrid() {
      if (!stickerGrid) return;
      stickerGrid.innerHTML = '';
      stickerLibrary.forEach(function (emoji) {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'sticker-item';
        button.textContent = emoji;
        button.addEventListener('pointerdown', function () {
          playEmojiSound(emoji);
          button.animate(
            [
              { transform: 'translateY(0) scale(1)' },
              { transform: 'translateY(-4px) scale(1.18)' },
              { transform: 'translateY(0) scale(1)' }
            ],
            { duration: 200, easing: 'ease-out' }
          );
        });
        button.addEventListener('click', function () {
          addStickerFromTray(emoji);
        });
        stickerGrid.appendChild(button);
      });
    }

    if (postText) {
      postText.addEventListener('dragover', function (event) {
        event.preventDefault();
      });
      postText.addEventListener('drop', function (event) {
        event.preventDefault();
        const emoji = event.dataTransfer.getData('text/plain');
        if (emoji) {
          insertAtCursor(postText, emoji + ' ');
          playEmojiSound(emoji);
        }
      });
    }

    if (emojiStage) {
      emojiStage.addEventListener('dragover', function (event) {
        event.preventDefault();
      });
      emojiStage.addEventListener('drop', function (event) {
        event.preventDefault();
        const emoji = event.dataTransfer.getData('text/plain');
        if (!emoji) return;
        const rect = emojiStage.getBoundingClientRect();
        const x = Math.max(0, Math.min(rect.width - 34, event.clientX - rect.left - 17));
        const y = Math.max(0, Math.min(rect.height - 34, event.clientY - rect.top - 17));
        addEmojiSticker(emoji, x, y);
      });
    }

    // --- MOVE ALL BUTTON INITIALIZATION TO BOTTOM OF BODY ---
    // This guarantees all elements exist before attaching listeners
    // and fixes all click issues for emoji, sticker, and GIF buttons.

    window.addEventListener('load', function () {
      buildRichEmojiRow();
      renderStickerGrid();

      // Initialize Emoji Button
      if (toggleEmojis) {
        toggleEmojis.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          try {
            const nextHidden = !emojiPanel.hidden;
            emojiPanel.hidden = nextHidden;
            toggleEmojis.textContent = nextHidden ? 'рЯШД Emoji' : 'рЯШД Emoji (close)';
            if (!nextHidden) {
              if (emojiTab) emojiTab.classList.add('active');
              if (stickerTab) stickerTab.classList.remove('active');
              if (emojiRow) emojiRow.hidden = false;
              if (stickerGrid) stickerGrid.hidden = true;
              buildRichEmojiRow();
            }
          } catch (err) {
            console.error('Error toggling emoji panel:', err);
          }
        });
      } else {
        console.warn('toggle-emojis button not found');
      }

      // Initialize Location Button
      if (toggleLocation) {
        toggleLocation.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          try {
            const captionField = document.getElementById('mvp-post-caption');
            const place = prompt('Add a location');
            if (!place || !place.trim()) return;
            insertAtCursor(captionField, 'рЯУН ' + place.trim() + ' ');
          } catch (err) {
            console.error('Error with location button:', err);
          }
        });
      }

      // Initialize Emoji Tab
      if (emojiTab) {
        emojiTab.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          try {
            emojiTab.classList.add('active');
            if (stickerTab) stickerTab.classList.remove('active');
            if (emojiRow) emojiRow.hidden = false;
            if (stickerGrid) stickerGrid.hidden = true;
            buildRichEmojiRow();
          } catch (err) {
            console.error('Error toggling emoji tab:', err);
          }
        });
      }

      // Initialize Sticker Tab
      if (stickerTab) {
        stickerTab.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          try {
            stickerTab.classList.add('active');
            if (emojiTab) emojiTab.classList.remove('active');
            if (emojiRow) emojiRow.hidden = true;
            if (stickerGrid) stickerGrid.hidden = false;
            renderStickerGrid();
          } catch (err) {
            console.error('Error toggling sticker tab:', err);
          }
        });
      }

      // Initialize GIF Button
      if (toggleGifs) {
        toggleGifs.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          try {
            gifPanel.hidden = !gifPanel.hidden;
            toggleGifs.textContent = gifPanel.hidden ? 'GIF' : 'GIF (close)';
            if (!gifPanel.hidden && gifGrid) {
              loadGifs('');
            }
          } catch (err) {
            console.error('Error toggling GIF panel:', err);
          }
        });
      } else {
        console.warn('toggle-gifs button not found');
      }

      if (toggleCreator && creatorPanel) {
        toggleCreator.addEventListener('click', function () {
        creatorPanel.hidden = !creatorPanel.hidden;
        toggleCreator.textContent = creatorPanel.hidden ? 'Open Creator Studio' : 'Close Creator Studio';
      });
    }

    function showCreatorPanel() {
      if (!creatorPanel) return;
      creatorPanel.hidden = false;
      if (toggleCreator) toggleCreator.textContent = 'Close Creator Studio';
      if (postText) postText.focus();
    }

    if (openCreatorMain) {
      openCreatorMain.addEventListener('click', function () {
        window.location.href = "{{ url_for('upload') }}?mode=post";
      });
    }

    (function(){
      const modal = document.getElementById('vf-create');
      const closeBtn = document.getElementById('vf-create-close');
      const title = document.getElementById('vf-create-title');

      const filePost = document.getElementById('vf-file-post');
      const fileStory = document.getElementById('vf-file-story');
      const fileReel = document.getElementById('vf-file-reel');

      const openPost = document.getElementById('open-creator-post');
      const openStory = document.getElementById('open-creator-photo');
      const openReel = document.getElementById('open-creator-reel');

      let mode = 'reel';

      function openCreate(nextMode){
        mode = nextMode || 'reel';
        if (!modal) return;
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
        setModeUI();
      }
      function closeCreate(){
        if (!modal) return;
        modal.hidden = true;
        document.body.style.overflow = '';
      }

      function setModeUI(){
        if (!title) return;
        title.textContent = mode === 'story' ? 'New story' : mode === 'post' ? 'New post' : mode === 'live' ? 'Go live' : 'New reel';
        document.querySelectorAll('.vf-tab').forEach(btn=>{
          btn.classList.toggle('active', btn.dataset.mode === mode);
        });
      }

      if (closeBtn) closeBtn.addEventListener('click', closeCreate);

      if (openPost) openPost.addEventListener('click', ()=>openCreate('post'));
      if (openReel) openReel.addEventListener('click', ()=>openCreate('reel'));
      if (openStory) openStory.addEventListener('click', ()=>openCreate('story'));

      document.querySelectorAll('.vf-tab').forEach(btn=>{
        btn.addEventListener('click', ()=>{
          mode = btn.dataset.mode;
          setModeUI();

          if (mode === 'live') {
            window.location.href = '/live_hub';
          }
        });
      });

      const camBtn = document.getElementById('vf-open-camera');
      if (camBtn) {
        camBtn.addEventListener('click', ()=>{
          if (mode === 'reel') fileReel && fileReel.click();
          else if (mode === 'story') fileStory && fileStory.click();
          else filePost && filePost.click();
        });
      }

      document.querySelectorAll('.vf-tile[data-url]').forEach(tile=>{
        tile.addEventListener('click', ()=>{
          const url = tile.dataset.url;
          const type = tile.dataset.type;
          window.location.href = '/upload?mode=' + encodeURIComponent(mode) + '&url=' + encodeURIComponent(url) + '&type=' + encodeURIComponent(type);
        });
      });
    })();

    // Initialize GIF Button
    if (toggleGifs) {
      toggleGifs.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        try {
          gifPanel.hidden = !gifPanel.hidden;
          toggleGifs.textContent = gifPanel.hidden ? 'GIF' : 'GIF (close)';
          if (!gifPanel.hidden && gifGrid) {
            loadGifs('');
          }
        } catch (err) {
          console.error('Error toggling GIF panel:', err);
        }
      });
    } else {
      console.warn('toggle-gifs button not found');
    }

    function renderGifGrid(items) {
      if (!gifGrid) return;
      gifGrid.innerHTML = '';
      if (!items.length) {
        gifGrid.innerHTML = '<div class="gif-empty">No GIFs found. Try a different keyword.</div>';
        return;
      }
      items.forEach(function (gif) {
        const node = document.createElement('button');
        node.type = 'button';
        node.className = 'gif-item';
        node.innerHTML = '<img src="' + gif.url + '" alt="' + gif.title + '">';
        node.addEventListener('click', function () {
          selectedGif = gif.url;
          if (mediaInput) mediaInput.value = '';
          gifGrid.querySelectorAll('.gif-item').forEach(function (g) { g.style.outline = 'none'; });
          node.style.outline = '2px solid rgba(255,154,61,.8)';
        });
        gifGrid.appendChild(node);
      });
    }
    function normalizeGiphyResults(data) {
      if (!data || !Array.isArray(data)) return [];
      return data.map(function (item) {
        const images = item.images || {};
        const url = (images.fixed_height_small && images.fixed_height_small.url) ||
          (images.fixed_width_small && images.fixed_width_small.url) ||
          (images.original && images.original.url) || '';
        return { title: item.title || 'GIF', url: url };
      }).filter(function (gif) { return gif.url; });
    }

    function loadGifs(query) {
      if (!gifGrid) return;
      const term = (query || '').trim();
      const endpoint = term
        ? 'https://api.giphy.com/v1/gifs/search?api_key=' + encodeURIComponent(GIPHY_API_KEY) + '&q=' + encodeURIComponent(term) + '&limit=18&rating=pg-13&lang=en'
        : 'https://api.giphy.com/v1/gifs/trending?api_key=' + encodeURIComponent(GIPHY_API_KEY) + '&limit=18&rating=pg-13';

      fetch(endpoint)
        .then(function (res) { return res.json(); })
        .then(function (payload) {
          const gifs = normalizeGiphyResults(payload && payload.data);
          renderGifGrid(gifs.length ? gifs : gifLibrary);
        })
        .catch(function () {
          renderGifGrid(gifLibrary);
        });
    }

    if (gifGrid) {
      loadGifs('');
    }

    if (gifSearch && gifGrid) {
      let gifTimer = null;
      gifSearch.addEventListener('input', function () {
        const needle = (gifSearch.value || '').trim();
        if (gifTimer) clearTimeout(gifTimer);
        gifTimer = setTimeout(function () {
          loadGifs(needle);
        }, 250);
      });
    }

    function aiReply(prompt) {
      const text = (prompt || '').toLowerCase();
      if (text.includes('hashtag')) return 'Try: #VybeFlow #OpenVerse #BeatTok #CreatorMode';
      if (text.includes('caption')) return 'Caption idea: "Late-night grind, bright-stage mindset. рЯФ•рЯОµ"';
      if (text.includes('challenge')) return 'Challenge idea: 15-sec hook flip + duet chain with your followers.';
      return 'Post idea: Share one real moment today, add 2 emojis, and ask a direct question for engagement.';
    }

    if (aiIdea && postText) {
      aiIdea.addEventListener('click', function () {
        postText.value += '\n' + aiReply('caption');
      });
    }

    if (aiSend && aiInput && aiLog) {
      aiSend.addEventListener('click', function () {
        const prompt = aiInput.value.trim();
        if (!prompt) return;
        aiLog.textContent = 'AI: ' + aiReply(prompt);
        aiInput.value = '';
      });
    }

    if (publishPost && postText && photoInput && feedLivePosts) {
      publishPost.addEventListener('click', async function () {
      const text = postText.value.trim();
      const photoName = (photoInput.files && photoInput.files.length) ? photoInput.files[0].name : '';
      if (!text && !selectedGif && (!photoInput.files || !photoInput.files.length)) {
        return;
      }

      if (creatorMode === 'reel' && (!photoInput.files || !photoInput.files.length || !photoInput.files[0].type.startsWith('video/'))) {
        alert('Select a video file to publish a reel.');
        return;
      }

      const moderation = await moderateDraft(text, photoName);
      if (!moderation.allowed) return;

      const post = document.createElement('article');
      post.className = 'live-post';

      const postUser = document.createElement('strong');
      postUser.textContent = '@{{ current_user.username }}';
      const postBody = document.createElement('div');
      postBody.textContent = text || 'New post';
      post.appendChild(postUser);
      post.appendChild(postBody);

      if (selectedGif) {
        const gif = document.createElement('img');
        gif.src = selectedGif;
        gif.alt = 'Selected GIF';
        post.appendChild(gif);
      }

      if (photoInput.files && photoInput.files.length) {
        const mediaFile = photoInput.files[0];
        if ((mediaFile.type || '').startsWith('video/')) {
          const video = document.createElement('video');
          video.src = URL.createObjectURL(mediaFile);
          video.controls = true;
          video.muted = true;
          post.appendChild(video);
        } else {
          const photo = document.createElement('img');
          photo.src = URL.createObjectURL(mediaFile);
          photo.alt = 'Uploaded photo preview';
          post.appendChild(photo);
        }
      }

      feedLivePosts.prepend(post);
      postText.value = '';
      photoInput.value = '';
      selectedGif = null;
      });
    }

    // ===== Reels Rail JS =====
    const reelsRow = document.getElementById('reels-row');
    const reelsForYou = document.getElementById('reels-for-you');
    const reelsChaos = document.getElementById('reels-chaos');

    const reelViewer = document.getElementById('reel-viewer');
    const reelViewClose = document.getElementById('reel-view-close');
    const reelViewVideo = document.getElementById('reel-view-video');
    const reelViewAvatar = document.getElementById('reel-view-avatar');
    const reelViewHandle = document.getElementById('reel-view-handle');
    const rvLike = document.getElementById('rv-like');
    const rvShare = document.getElementById('rv-share');
    const rvSound = document.getElementById('rv-sound');

    let rvSoundOn = false;
    let activeReelCards = [];
    let activeReelIndex = -1;
    let lastWheelAt = 0;
    let touchStartY = null;

    function toNumber(value) {
      const num = parseFloat(value);
      return Number.isFinite(num) ? num : 0;
    }

    function computeReelScore(card, index) {
      const likes = toNumber(card.dataset.likes);
      const comments = toNumber(card.dataset.comments);
      const views = toNumber(card.dataset.views);
      const createdAtRaw = card.dataset.createdAt || '';

      let recencyBoost = 0;
      if (createdAtRaw) {
        const createdAt = new Date(createdAtRaw);
        if (!Number.isNaN(createdAt.getTime())) {
          const hoursAgo = (Date.now() - createdAt.getTime()) / 3600000;
          recencyBoost = Math.max(0, 72 - hoursAgo) * 0.55;
        }
      }

      const idSalt = String(card.dataset.reelId || index + 1)
        .split('')
        .reduce(function (sum, ch) { return sum + ch.charCodeAt(0); }, 0);
      const exploreBoost = (idSalt % 9) * 1.4;

      const score = (likes * 3.4) + (comments * 4.1) + (views * 0.25) + recencyBoost + exploreBoost;
      return Math.round(score * 10) / 10;
    }

    function applyHeatBadge(card, score) {
      const heat = card.querySelector('.reel-heat');
      if (!heat) return;
      if (score >= 40) {
        card.classList.add('hot');
        heat.textContent = score >= 85 ? 'рЯФ• BLAZING' : score >= 60 ? 'рЯФ• HOT' : 'рЯФ• TRENDING';
      } else {
        card.classList.remove('hot');
      }
    }

    function sortReelsByAlgorithm() {
      if (!reelsRow) return;
      const cards = Array.from(reelsRow.querySelectorAll('.reel-card'));
      cards.forEach(function (card, index) {
        const score = computeReelScore(card, index);
        card.dataset.score = String(score);
        applyHeatBadge(card, score);
      });
      cards.sort(function (a, b) {
        return toNumber(b.dataset.score) - toNumber(a.dataset.score);
      });
      cards.forEach(function (card) { reelsRow.appendChild(card); });
      activeReelCards = cards;
      if (reelsForYou) reelsForYou.classList.add('active-sort');
    }

    function syncActiveReels() {
      if (!reelsRow) {
        activeReelCards = [];
        return;
      }
      activeReelCards = Array.from(reelsRow.querySelectorAll('.reel-card'));
    }

    function setViewerReel(card) {
      if (!card || !reelViewer || !reelViewVideo) return;

      const videoUrl = card.dataset.video || '';
      const coverUrl = card.dataset.cover || '';
      const user = card.dataset.user || 'vybeflow';
      const avatar = card.dataset.avatar || '{{ current_user.avatar_url }}';

      reelViewAvatar.src = avatar;
      reelViewHandle.textContent = '@' + user.replace(/^@/, '');

      reelViewVideo.pause();
      reelViewVideo.removeAttribute('src');
      reelViewVideo.poster = coverUrl || '';
      reelViewVideo.load();

      if (videoUrl) {
        reelViewVideo.src = videoUrl;
        reelViewVideo.muted = !rvSoundOn;
        reelViewVideo.play().catch(function () {});
      }
    }

    function openReelViewer(card) {
      if (!reelViewer || !reelViewVideo) return;
      syncActiveReels();
      activeReelIndex = activeReelCards.indexOf(card);
      if (activeReelIndex < 0) activeReelIndex = 0;

      reelViewer.hidden = false;
      document.body.style.overflow = 'hidden';
      setViewerReel(activeReelCards[activeReelIndex] || card);
    }

    function stepViewerReel(direction) {
      if (!activeReelCards.length) return;
      const nextIndex = activeReelIndex + direction;
      if (nextIndex < 0 || nextIndex >= activeReelCards.length) return;
      activeReelIndex = nextIndex;
      setViewerReel(activeReelCards[activeReelIndex]);
    }

    function closeReelViewer() {
      if (!reelViewer || !reelViewVideo) return;
      reelViewer.hidden = true;
      document.body.style.overflow = '';
      reelViewVideo.pause();
      reelViewVideo.removeAttribute('src');
      reelViewVideo.load();
      activeReelIndex = -1;
    }

    if (reelViewClose) reelViewClose.addEventListener('click', closeReelViewer);
    if (reelViewer) {
      reelViewer.addEventListener('click', function (e) {
        if (e.target === reelViewer) closeReelViewer();
      });

      reelViewer.addEventListener('wheel', function (event) {
        if (reelViewer.hidden) return;
        const now = Date.now();
        if (now - lastWheelAt < 320) return;
        if (Math.abs(event.deltaY) < 14) return;
        lastWheelAt = now;
        if (event.deltaY > 0) stepViewerReel(1);
        else stepViewerReel(-1);
      }, { passive: true });

      reelViewer.addEventListener('touchstart', function (event) {
        if (!event.touches || !event.touches.length) return;
        touchStartY = event.touches[0].clientY;
      }, { passive: true });

      reelViewer.addEventListener('touchend', function (event) {
        if (touchStartY === null || !event.changedTouches || !event.changedTouches.length) return;
        const endY = event.changedTouches[0].clientY;
        const deltaY = endY - touchStartY;
        touchStartY = null;
        if (Math.abs(deltaY) < 36) return;
        if (deltaY < 0) stepViewerReel(1);
        else stepViewerReel(-1);
      }, { passive: true });
    }

    document.addEventListener('keydown', function (event) {
      if (!reelViewer || reelViewer.hidden) return;
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        stepViewerReel(1);
      }
      if (event.key === 'ArrowUp') {
        event.preventDefault();
        stepViewerReel(-1);
      }
    });

    // Sound toggle
    if (rvSound && reelViewVideo) {
      rvSound.addEventListener('click', function () {
        rvSoundOn = !rvSoundOn;
        reelViewVideo.muted = !rvSoundOn;
        rvSound.textContent = rvSoundOn ? 'рЯФК' : 'рЯФЗ';
        if (rvSoundOn) reelViewVideo.play().catch(function () {});
      });
    }

    // Like + Share
    if (rvLike) {
      rvLike.addEventListener('click', function () {
        rvLike.textContent = rvLike.textContent.includes('рЯТ•') ? 'рЯФ•' : 'рЯТ•';
      });
    }
    if (rvShare) {
      rvShare.addEventListener('click', function () {
        const url = window.location.href;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(function () {
            rvShare.textContent = 'вЬЕ';
            setTimeout(function () { rvShare.textContent = 'рЯЪА'; }, 900);
          });
        }
      });
    }

    // Hover preview (desktop) using an injected video element per card
    function attachHoverPreview(card) {
      let hoverVid = null;
      const videoUrl = card.dataset.video || '';
      if (!videoUrl) return; // skip demo cards

      function ensureVid() {
        if (hoverVid) return hoverVid;
        hoverVid = document.createElement('video');
        hoverVid.src = videoUrl;
        hoverVid.muted = true;
        hoverVid.playsInline = true;
        hoverVid.loop = true;
        hoverVid.preload = 'metadata';
        hoverVid.style.position = 'absolute';
        hoverVid.style.inset = '0';
        hoverVid.style.width = '100%';
        hoverVid.style.height = '100%';
        hoverVid.style.objectFit = 'cover';
        hoverVid.style.zIndex = '2';
        hoverVid.style.opacity = '0';
        hoverVid.style.transition = 'opacity .18s ease';
        card.appendChild(hoverVid);
        return hoverVid;
      }

      // desktop hover
      card.addEventListener('mouseenter', function () {
        const v = ensureVid();
        v.currentTime = 0.01;
        v.play().catch(function () {});
        v.style.opacity = '1';
        bumpFlex(card, 1);
        card.classList.add('vybe-hot');
      });

      card.addEventListener('mouseleave', function () {
        if (!hoverVid) return;
        hoverVid.pause();
        hoverVid.style.opacity = '0';
        card.classList.remove('vybe-hot');
      });

      // mobile tap opens viewer
      card.addEventListener('click', function () { openReelViewer(card); });

      card.querySelectorAll('.reel-overlay-btn').forEach(function (btn) {
        btn.addEventListener('click', function (event) {
          event.stopPropagation();
          const countNode = btn.querySelector('span');
          if (countNode) {
            const next = (parseInt(countNode.textContent || '0', 10) || 0) + 1;
            countNode.textContent = String(next);
          }
          if (btn.dataset.action === 'like') {
            const likes = toNumber(card.dataset.likes) + 1;
            card.dataset.likes = String(likes);
          }
          if (btn.dataset.action === 'comment') {
            const comments = toNumber(card.dataset.comments) + 1;
            card.dataset.comments = String(comments);
          }
          const score = computeReelScore(card, 0);
          card.dataset.score = String(score);
          applyHeatBadge(card, score);
        });
      });
    }

    function bumpFlex(card, by) {
      const num = card.querySelector('.reel-flex-num');
      if (!num) return;
      const next = (parseInt(num.textContent || '0', 10) || 0) + (by || 1);
      num.textContent = String(next);

      // quick pop animation
      num.animate(
        [{ transform: 'scale(1)', filter: 'brightness(1)' }, { transform: 'scale(1.25)', filter: 'brightness(1.35)' }, { transform: 'scale(1)', filter: 'brightness(1)' }],
        { duration: 240, easing: 'ease-out' }
      );
    }

    if (reelsRow) {
      sortReelsByAlgorithm();
      reelsRow.querySelectorAll('.reel-card').forEach(function (card) {
        // if demo card, just open viewer (no video)
        if (card.classList.contains('demo')) {
          card.addEventListener('click', function () { openReelViewer(card); });
          return;
        }
        attachHoverPreview(card);
      });
    }

    if (reelsForYou) {
      reelsForYou.addEventListener('click', function () {
        sortReelsByAlgorithm();
      });
    }

    if (reelsChaos) {
      reelsChaos.addEventListener('click', function () {
        if (!reelsRow) return;
        reelsRow.querySelectorAll('.reel-card').forEach(function (card, i) {
          const rot = ((Math.random() * 2.2) - 1.1).toFixed(2);
          const dy = ((Math.random() * 6) - 3).toFixed(0);
          card.style.transform = 'translateY(' + dy + 'px) rotate(' + rot + 'deg)';
          setTimeout(function () { card.style.transform = ''; }, 240 + (i % 6) * 20);
          bumpFlex(card, 1);
          card.classList.add('vybe-hot');
          setTimeout(function () { card.classList.remove('vybe-hot'); }, 900);
        });
      });
    }

    let gameScore = 0;
    let gameTarget = Math.floor(Math.random() * 5) + 1;
    const gameHint = document.getElementById('game-hint');
    const gameScoreNode = document.getElementById('game-score');
    document.querySelectorAll('.game-guess').forEach(function (button) {
      button.addEventListener('click', function () {
        const guess = Number(button.dataset.n);
        if (guess === gameTarget) {
          gameScore += 1;
          gameHint.textContent = 'Correct! New number generated.';
          gameTarget = Math.floor(Math.random() * 5) + 1;
        } else {
          gameHint.textContent = 'Missed. Try again.';
        }
        gameScoreNode.textContent = 'Score: ' + gameScore;
      });
    });
    });
  })();
</script>
<script>
  (function () {
    const postList = document.getElementById('mvp-posts-list');
    const feedback = document.getElementById('mvp-post-feedback');
    const captionInput = document.getElementById('mvp-post-caption');
    const bgInput = document.getElementById('mvp-post-bg');
    const bgCustomInput = document.getElementById('mvp-post-bg-custom');
    const visibilityInput = document.getElementById('mvp-post-visibility');
    const mediaInput = document.getElementById('mvp-post-media');
    const createBtn = document.getElementById('mvp-post-create');

    if (!postList || !createBtn) return;

    let postsCache = [];
    const quickReplies = ['рЯФ• facts', 'Big vybe', 'Say less', 'Drop more', 'This is clean'];
    let bgCustomTouched = false;

    if (bgCustomInput) {
      bgCustomInput.addEventListener('input', function () {
        bgCustomTouched = true;
      });
    }

    if (mediaInput) {
      mediaInput.addEventListener('change', function () {
        if (mediaInput.files && mediaInput.files.length) {
          selectedGif = null;
        }
      });
    }

    function isHexColor(value) {
      if (!value || value[0] !== '#') return false;
      if (value.length !== 4 && value.length !== 7) return false;
      for (let i = 1; i < value.length; i += 1) {
        const ch = value[i].toLowerCase();
        if (!('0123456789abcdef'.includes(ch))) return false;
      }
      return true;
    }

    function isLightColor(hex) {
      const raw = hex.length === 4
        ? '#' + hex[1] + hex[1] + hex[2] + hex[2] + hex[3] + hex[3]
        : hex;
      const r = parseInt(raw.slice(1, 3), 16) || 0;
      const g = parseInt(raw.slice(3, 5), 16) || 0;
      const b = parseInt(raw.slice(5, 7), 16) || 0;
      const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
      return luminance > 0.62;
    }

    function setFeedback(text, isError) {
      if (!feedback) return;
      feedback.textContent = text || '';
      feedback.style.color = isError ? 'rgba(255,120,120,.95)' : 'var(--muted)';
    }

    const emojiRegex = /([\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}])/gu;

    function escapeHtml(text) {
      return String(text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function wrapEmojis(text) {
      const safe = escapeHtml(text);
      return safe.replace(emojiRegex, '<span class="emoji-3d">$1</span>');
    }

    function applyEmojiMotionToStaticPosts() {
      document.querySelectorAll('.post-body').forEach(function (node) {
        const raw = node.textContent || '';
        node.innerHTML = wrapEmojis(raw);
      });
    }

    function whenLabel(stamp) {
      if (!stamp) return 'Just now';
      return stamp.replace('T', ' ').replace('Z', '');
    }

    function byParent(comments, parentId) {
      return comments.filter(function (item) {
        return (item.parent_id || null) === (parentId || null);
      });
    }

    function postAction(url, payload) {
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {})
      }).then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); });
    }

    function postFormAction(url, formData) {
      return fetch(url, {
        method: 'POST',
        body: formData
      }).then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); });
    }

    const voiceStore = new WeakMap();

    function hasAudio(input) {
      return voiceStore.has(input) || (input && input.files && input.files[0]);
    }

    function clearAudio(input, preview) {
      if (!input) return;
      voiceStore.delete(input);
      if (input.files) input.value = '';
      if (preview) preview.innerHTML = '';
    }

    function appendAudio(form, input, fieldName) {
      if (!input) return;
      const blob = voiceStore.get(input);
      if (blob) {
        form.append(fieldName, blob, 'voice-note.webm');
        return;
      }
      if (input.files && input.files[0]) {
        form.append(fieldName, input.files[0]);
      }
    }

    function attachRecorder(button, input, preview) {
      if (!button || !input) return;
      let mediaRecorder = null;
      let chunks = [];
      let recording = false;
      let analyser = null;
      let animationId = null;

      button.addEventListener('click', async function () {
        if (recording && mediaRecorder) {
          mediaRecorder.stop();
          button.classList.remove('recording');
          button.textContent = 'рЯОЩпЄП Record';
          return;
        }
        if (!navigator.mediaDevices || !window.MediaRecorder) {
          alert('Recording not supported in this browser.');
          return;
        }
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true, echoCancellation: true });
          const audioContext = new (window.AudioContext || window.webkitAudioContext)();
          analyser = audioContext.createAnalyser();
          const source = audioContext.createMediaStreamSource(stream);
          source.connect(analyser);
          analyser.fftSize = 256;
          
          mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm;codecs=opus' });
          chunks = [];
          recording = true;
          button.classList.add('recording');
          button.textContent = 'вПєпЄП Stop Recording...';
          
          mediaRecorder.addEventListener('dataavailable', function (event) {
            if (event.data && event.data.size) chunks.push(event.data);
          });
          
          mediaRecorder.addEventListener('stop', function () {
            recording = false;
            button.classList.remove('recording');
            button.textContent = 'рЯОЩпЄП Record';
            cancelAnimationFrame(animationId);
            stream.getTracks().forEach(function (track) { track.stop(); });
            audioContext.close();
            
            const blob = new Blob(chunks, { type: 'audio/webm' });
            voiceStore.set(input, blob);
            if (preview) {
              preview.innerHTML = '';
              const audio = document.createElement('audio');
              audio.className = 'mvp-voice-audio';
              audio.controls = true;
              audio.src = URL.createObjectURL(blob);
              preview.appendChild(audio);
            }
          });
          
          mediaRecorder.start();
          
          // Animate waveform during recording
          function animateWaveform() {
            if (!recording) return;
            const dataArray = new Uint8Array(analyser.frequencyBinCount);
            analyser.getByteFrequencyData(dataArray);
            animationId = requestAnimationFrame(animateWaveform);
          }
          animateWaveform();
        } catch (error) {
          alert('Microphone access blocked. Please enable microphone access in your browser settings.');
        }
      });

      input.addEventListener('change', function () {
        voiceStore.delete(input);
        if (preview) preview.innerHTML = '';
      });
    }

    function buildVoiceRow() {
      const row = document.createElement('div');
      row.className = 'mvp-voice-row';

      const recordBtn = document.createElement('button');
      recordBtn.type = 'button';
      recordBtn.className = 'mvp-voice-btn';
      recordBtn.textContent = 'рЯОЩпЄП Record';

      const audioInput = document.createElement('input');
      audioInput.type = 'file';
      audioInput.accept = 'audio/*';
      audioInput.className = 'mvp-voice-input';
      audioInput.style.display = 'none';

      const preview = document.createElement('div');
      row.appendChild(recordBtn);
      row.appendChild(audioInput);
      row.appendChild(preview);

      attachRecorder(recordBtn, audioInput, preview);

      return { row: row, input: audioInput, preview: preview };
    }

    function refreshPosts() {
      return fetch("{{ url_for('api_posts_list') }}")
        .then(function (res) { return res.json(); })
        .then(function (payload) {
          postsCache = Array.isArray(payload.posts) ? payload.posts : [];
          renderPosts();
        })
        .catch(function () {
          setFeedback('Unable to load posts right now.', true);
        });
    }

    function renderCommentNode(post, comment, allComments) {
      const node = document.createElement('div');
      node.className = 'mvp-comment' + (comment.parent_id ? ' child' : '');

      const header = document.createElement('div');
      header.className = 'mvp-comment-meta';
      header.textContent = '@' + comment.author_username + ' вАҐ ' + whenLabel(comment.created_at);

      const text = document.createElement('div');
      text.className = 'mvp-comment-text';
      text.innerHTML = wrapEmojis(comment.content);

      const controls = document.createElement('div');
      controls.className = 'mvp-reply-chips';

      const likeBtn = document.createElement('button');
      likeBtn.type = 'button';
      likeBtn.className = 'mvp-mini';
      likeBtn.textContent = (comment.liked ? 'рЯТЫ Liked ' : 'рЯ§Н Like ') + '(' + (comment.like_count || 0) + ')';
      likeBtn.addEventListener('click', function () {
        postAction('/api/comments/' + encodeURIComponent(comment.id) + '/like', {})
          .then(function () { return refreshPosts(); });
      });
      controls.appendChild(likeBtn);

      quickReplies.forEach(function (chipText) {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'mvp-mini';
        chip.textContent = chipText;
        chip.addEventListener('click', function () {
          const input = node.querySelector('.mvp-comment-input');
          if (input) input.value = chipText;
        });
        controls.appendChild(chip);
      });

      const noteForm = document.createElement('div');
      noteForm.className = 'mvp-comment-form';

      const replyInput = document.createElement('input');
      replyInput.className = 'mvp-comment-input mvp-post-comment-input';
      replyInput.placeholder = 'Reply or leave a quick note...';

      const replyBtn = document.createElement('button');
      replyBtn.type = 'button';
      replyBtn.className = 'mvp-mini';
      replyBtn.textContent = 'Reply';
      const replyVoice = buildVoiceRow();
      replyBtn.addEventListener('click', function () {
        const value = (replyInput.value || '').trim();
        if (!value && !hasAudio(replyVoice.input)) return;
        const form = new FormData();
        form.append('content', value);
        form.append('parent_id', comment.id);
        appendAudio(form, replyVoice.input, 'voice_note');
        postFormAction('/api/posts/' + encodeURIComponent(post.id) + '/comments', form)
          .then(function (resp) {
            if (!resp.ok) {
              setFeedback(resp.data && resp.data.error ? resp.data.error : 'Unable to reply.', true);
              return;
            }
            replyInput.value = '';
            clearAudio(replyVoice.input, replyVoice.preview);
            refreshPosts();
          });
      });
      noteForm.appendChild(replyInput);
      noteForm.appendChild(replyBtn);
      noteForm.appendChild(noteBtn);
      noteForm.appendChild(replyVoice.row);

      node.appendChild(header);
      if (comment.content) {
        node.appendChild(text);
      }

      if (comment.voice_note_url) {
        const audioContainer = document.createElement('div');
        audioContainer.style.marginTop = '8px';
        
        const audioLabel = document.createElement('div');
        audioLabel.style.fontSize = '12px';
        audioLabel.style.color = 'rgba(255, 154, 61, 0.8)';
        audioLabel.style.marginBottom = '6px';
        audioLabel.textContent = 'рЯОЩпЄП Voice Note';
        audioContainer.appendChild(audioLabel);
        
        const audio = document.createElement('audio');
        audio.className = 'mvp-voice-audio';
        audio.controls = true;
        audio.src = comment.voice_note_url;
        audioContainer.appendChild(audio);
        node.appendChild(audioContainer);
      }

      if (comment.note_text) {
        const noteText = document.createElement('div');
        noteText.className = 'mvp-comment-note';
        noteText.innerHTML = wrapEmojis('рЯУЭ ' + comment.note_text);
        node.appendChild(noteText);
      }

      (comment.notes || []).forEach(function (note) {
        if (note.text) {
          const line = document.createElement('div');
          line.className = 'mvp-note-line';
          line.innerHTML = wrapEmojis('вАҐ ' + note.text + ' вАФ ' + (note.by || 'user'));
          node.appendChild(line);
        }

        if (note.audio_url) {
          const audioContainer = document.createElement('div');
          audioContainer.style.marginTop = '6px';
          audioContainer.style.marginLeft = '8px';
          
          if (!note.text) {
            const voiceLabel = document.createElement('div');
            voiceLabel.style.fontSize = '11px';
            voiceLabel.style.color = 'rgba(255, 154, 61, 0.7)';
            voiceLabel.style.marginBottom = '4px';
            voiceLabel.textContent = 'рЯОЩпЄП ' + (note.by || 'User') + ' left a voice note';
            audioContainer.appendChild(voiceLabel);
          }
          
          const noteAudio = document.createElement('audio');
          noteAudio.className = 'mvp-voice-audio';
          noteAudio.controls = true;
          noteAudio.src = note.audio_url;
          audioContainer.appendChild(noteAudio);
          node.appendChild(audioContainer);
        }
      });

      node.appendChild(controls);
      node.appendChild(noteForm);

      const children = byParent(allComments, comment.id);
      children.forEach(function (child) {
        node.appendChild(renderCommentNode(post, child, allComments));
      });

      return node;
    }

    function renderPosts() {
      postList.innerHTML = '';

      if (!postsCache.length) {
        const empty = document.createElement('div');
        empty.className = 'mvp-feedback';
        empty.textContent = 'No posts yet. Publish one above.';
        postList.appendChild(empty);
        return;
      }

      postsCache.forEach(function (post) {
        const card = document.createElement('article');
        const bgStyle = post.bg_style || 'default';
        card.className = 'mvp-card';
        if (isHexColor(bgStyle)) {
          card.classList.add('bg-custom');
          card.style.background = bgStyle;
          card.style.color = isLightColor(bgStyle) ? '#0b0b0b' : '#f7f7fb';
        } else {
          card.classList.add('bg-' + bgStyle);
        }

        const head = document.createElement('div');
        head.className = 'mvp-head';

        const user = document.createElement('div');
        user.className = 'mvp-user';
        user.innerHTML = '<img class="mvp-avatar" src="' + (post.author_avatar_url || '') + '" alt="avatar">' +
          '<div><div class="mvp-title">' + post.author_username + '</div>' +
          '<div class="mvp-sub">' + whenLabel(post.created_at) + ' вАҐ ' + (post.visibility || 'Public') + '</div></div>';

        const actions = document.createElement('div');
        if (post.can_edit) {
          const editBtn = document.createElement('button');
          editBtn.type = 'button';
          editBtn.className = 'mvp-mini';
          editBtn.textContent = 'Edit';
          editBtn.addEventListener('click', function () {
            const nextCaption = prompt('Edit caption', post.caption || '');
            if (nextCaption === null) return;
            fetch('/api/posts/' + encodeURIComponent(post.id), {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ caption: nextCaption, bg_style: post.bg_style, visibility: post.visibility })
            }).then(function () { return refreshPosts(); });
          });
          actions.appendChild(editBtn);

          const deleteBtn = document.createElement('button');
          deleteBtn.type = 'button';
          deleteBtn.className = 'mvp-mini';
          deleteBtn.textContent = 'Delete';
          deleteBtn.addEventListener('click', function () {
            if (!confirm('Delete this post?')) return;
            fetch('/api/posts/' + encodeURIComponent(post.id), { method: 'DELETE' })
              .then(function () { return refreshPosts(); });
          });
          actions.appendChild(deleteBtn);
        }

        head.appendChild(user);
        head.appendChild(actions);

        const caption = document.createElement('div');
        caption.className = 'mvp-caption';
        caption.innerHTML = wrapEmojis(post.caption || '');

        card.appendChild(head);
        if (post.caption) card.appendChild(caption);

        if (post.media_url) {
          const media = document.createElement('div');
          media.className = 'mvp-media';
          if ((post.media_type || '').toLowerCase() === 'video') {
            media.innerHTML = '<video src="' + post.media_url + '" controls preload="metadata"></video>';
          } else {
            media.innerHTML = '<img src="' + post.media_url + '" alt="Post media">';
          }
          card.appendChild(media);
        }

        if (Array.isArray(post.stickers) && post.stickers.length) {
          const stickerLayer = document.createElement('div');
          stickerLayer.className = 'mvp-stickers';
          post.stickers.forEach(function (sticker) {
            if (!sticker || !sticker.emoji) return;
            const node = document.createElement('span');
            node.className = 'mvp-sticker';
            node.textContent = sticker.emoji;
            const x = Math.max(0, Math.min(100, Number(sticker.x) || 0));
            const y = Math.max(0, Math.min(100, Number(sticker.y) || 0));
            node.style.left = x + '%';
            node.style.top = y + '%';
            node.addEventListener('mouseenter', function () {
              if (window.VybeEmojiSound) window.VybeEmojiSound(sticker.emoji);
            });
            stickerLayer.appendChild(node);
          });
          card.appendChild(stickerLayer);
        }

        const postActions = document.createElement('div');
        postActions.className = 'mvp-actions';

        const likeBtn = document.createElement('button');
        likeBtn.type = 'button';
        likeBtn.className = 'mvp-chip';
        likeBtn.textContent = (post.liked ? 'рЯФ• Liked ' : 'рЯФ• Like ') + '(' + (post.like_count || 0) + ')';
        likeBtn.addEventListener('click', function () {
          postAction('/api/posts/' + encodeURIComponent(post.id) + '/like', {})
            .then(function () { return refreshPosts(); });
        });

        const reactBtn = document.createElement('button');
        reactBtn.type = 'button';
        reactBtn.className = 'mvp-chip';
        reactBtn.textContent = 'React ' + (post.current_reaction || 'вЪ°');
        reactBtn.addEventListener('click', function () {
          const emoji = prompt('Reaction emoji', post.current_reaction || 'рЯФ•');
          if (!emoji) return;
          postAction('/api/posts/' + encodeURIComponent(post.id) + '/react', { emoji: emoji })
            .then(function () { return refreshPosts(); });
        });

        const commentBtn = document.createElement('button');
        commentBtn.type = 'button';
        commentBtn.className = 'mvp-chip';
        commentBtn.textContent = 'рЯТђ Comment (' + (post.comment_count || 0) + ')';
        commentBtn.addEventListener('click', function () {
          const input = card.querySelector('.mvp-post-comment-input');
          if (input) input.focus();
        });

        postActions.appendChild(likeBtn);
        postActions.appendChild(reactBtn);
        postActions.appendChild(commentBtn);
        card.appendChild(postActions);

        const commentForm = document.createElement('div');
        commentForm.className = 'mvp-comment-form';
        const commentInput = document.createElement('input');
        commentInput.className = 'mvp-comment-input mvp-post-comment-input';
        commentInput.placeholder = 'Add a comment...';
        const sendBtn = document.createElement('button');
        sendBtn.type = 'button';
        sendBtn.className = 'mvp-mini';
        sendBtn.textContent = 'Send';
        const commentVoice = buildVoiceRow();
        sendBtn.addEventListener('click', function () {
          const value = (commentInput.value || '').trim();
          if (!value && !hasAudio(commentVoice.input)) return;
          const form = new FormData();
          form.append('content', value);
          appendAudio(form, commentVoice.input, 'voice_note');
          postFormAction('/api/posts/' + encodeURIComponent(post.id) + '/comments', form)
            .then(function (resp) {
              if (!resp.ok) {
                setFeedback(resp.data && resp.data.error ? resp.data.error : 'Unable to comment.', true);
                return;
              }
              commentInput.value = '';
              clearAudio(commentVoice.input, commentVoice.preview);
              refreshPosts();
            });
        });
        commentForm.appendChild(commentInput);
        commentForm.appendChild(sendBtn);
        commentForm.appendChild(commentVoice.row);
        card.appendChild(commentForm);

        const commentsWrap = document.createElement('div');
        commentsWrap.className = 'mvp-comments';
        const roots = byParent(post.comments || [], null);
        roots.forEach(function (comment) {
          commentsWrap.appendChild(renderCommentNode(post, comment, post.comments || []));
        });
        card.appendChild(commentsWrap);

        postList.appendChild(card);
      });
      applyEmojiMotionToStaticPosts();
    }

    createBtn.addEventListener('click', function () {
      const form = new FormData();
      const nextCaption = (captionInput.value || '').trim();
      const fallbackBg = bgInput ? (bgInput.value || 'default') : 'default';
      const bgValue = (bgCustomInput && bgCustomTouched && bgCustomInput.value) ? bgCustomInput.value : fallbackBg;
      form.append('caption', nextCaption);
      form.append('bg_style', bgValue || 'default');
      form.append('visibility', visibilityInput.value || 'Public');
      if (mediaInput.files && mediaInput.files[0]) {
        form.append('media', mediaInput.files[0]);
      } else if (selectedGif) {
        form.append('gif_url', selectedGif);
      }

      createBtn.disabled = true;
      setFeedback('Publishing...', false);

      fetch("{{ url_for('api_posts_create') }}", {
        method: 'POST',
        body: form
      })
        .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
        .then(function (resp) {
          if (!resp.ok) {
            setFeedback(resp.data && resp.data.error ? resp.data.error : 'Could not publish post.', true);
            return;
          }
          captionInput.value = '';
          mediaInput.value = '';
          selectedGif = null;
          if (bgCustomInput) {
            bgCustomTouched = false;
          }
          if (resp.data && resp.data.post && resp.data.post.id) {
            const undoBtn = document.createElement('button');
            undoBtn.type = 'button';
            undoBtn.className = 'mvp-undo';
            undoBtn.textContent = 'Undo';
            setFeedback('Post published.', false);
            if (feedback) {
              feedback.textContent = 'Post published.';
              feedback.appendChild(undoBtn);
            }
            const undoId = resp.data.post.id;
            const timer = setTimeout(function () {
              setFeedback('Post published.', false);
            }, 10000);
            undoBtn.addEventListener('click', function () {
              clearTimeout(timer);
              fetch('/api/posts/' + encodeURIComponent(undoId), { method: 'DELETE' })
                .then(function () { return refreshPosts(); })
                .finally(function () { setFeedback('Post removed.', false); });
            });
          } else {
            setFeedback('Post published.', false);
            return refreshPosts();
          }
          return refreshPosts();
        })
        .catch(function () {
          setFeedback('Could not publish post.', true);
        })
        .finally(function () {
          createBtn.disabled = false;
        });
    });

    refreshPosts();
  })();
</script>
<script>
  (function () {
    const holder = document.getElementById('vf-sparkles');
    if (!holder) return;

    const COUNT = 42;
    const sparkles = [];

    function rand(min, max){ return Math.random() * (max - min) + min; }

    function placeSpark(el){
      const x = rand(0, 100);
      const y = rand(0, 100);
      const size = rand(4, 9);

      el.style.left = x + 'vw';
      el.style.top  = y + 'vh';
      el.style.width = size + 'px';
      el.style.height = size + 'px';

      el.style.setProperty('--dur', rand(2.4, 4.6).toFixed(2) + 's');
      el.style.setProperty('--delay', rand(0, 2.0).toFixed(2) + 's');
    }

    for (let i = 0; i < COUNT; i++){
      const s = document.createElement('span');
      s.className = 'vf-spark';

      placeSpark(s);

      s.addEventListener('animationiteration', function () {
        placeSpark(s);
      });

      holder.appendChild(s);
      sparkles.push(s);
    }
  })();
</script>
{% endblock %}
