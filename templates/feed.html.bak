<style>
/* --- Facebook-like post card --- */
.feed-wrap{
  max-width: 720px;
  margin: 18px auto;
  padding: 0 12px 40px;
}
.post-card{
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 18px;
  background: rgba(0,0,0,.45);
  backdrop-filter: blur(14px);
  box-shadow: 0 10px 30px rgba(0,0,0,.45);
  overflow: hidden;
  margin: 14px 0;
}
.post-head{
  display:flex;
  gap: 12px;
  padding: 14px 14px 10px;
  align-items: center;
}
.post-avatar{
  width: 44px;
  height: 44px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(255,154,61,.7), rgba(255,72,0,.45));
  display: grid;
  place-items: center;
  font-weight: 900;
}
.post-meta{
  display:flex;
  flex-direction: column;
  gap: 2px;
}
.post-name{
  font-weight: 900;
  font-size: 15px;
  line-height: 1.1;
}
.post-time{
  font-size: 12px;
  color: rgba(255,255,255,.65);
}
.post-body{
  padding: 0 14px 14px;
}
.post-caption{
  font-size: 18px;           /* BIG like Facebook */
  line-height: 1.45;
  color: rgba(255,255,255,.95);
  white-space: normal;
}
.post-media img, .post-media video{
  width: 100%;
  display:block;
  max-height: 520px;
  object-fit: cover;
}
.post-footer{
  padding: 10px 14px 14px;
  border-top: 1px solid rgba(255,255,255,.10);
  display:flex;
  justify-content: space-between;
  align-items:center;
  gap: 10px;
}
.reaction-row{
  display:flex;
  gap: 8px;
  flex-wrap: wrap;
}
.react-btn{
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.06);
  color:#fff;
  border-radius: 999px;
  padding: 8px 12px;
  font-weight: 800;
  cursor:pointer;
}
.react-btn:hover{ transform: translateY(-1px); }

/* --- Emoji animations for posted captions --- */
.cap-emoji{
  display:inline-block;
  font-size: 1.25em; /* bigger than text */
  line-height: 1;
  vertical-align: -0.15em;
  margin: 0 .03em;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,.26));
  text-shadow: 0 0 12px color-mix(in srgb, var(--brand2, #ff7a1f) 60%, transparent);
  will-change: transform, filter;
}
.cap-glow{ animation: emojiGlow 2.8s ease-in-out infinite; }
.cap-cry{ animation: emojiGlow 2.8s ease-in-out infinite, emojiCrying 3.2s ease-in-out infinite; }
.cap-laugh{ animation: emojiGlow 2.8s ease-in-out infinite, emojiLaughing 2.8s ease-in-out infinite; }
.cap-fire{ animation: emojiGlow 2.8s ease-in-out infinite, emojiSpinning 2.4s linear infinite; }
.cap-shock{ animation: emojiGlow 2.8s ease-in-out infinite, emojiShocked .5s ease-in-out infinite; }

/* --- Sticker stage on posted content --- */
.post-stage{
  position: relative;
  width: 100%;
  height: 220px;
  margin-top: 10px;
  border-radius: 14px;
  border: 1px dashed rgba(255,255,255,.22);
  background: rgba(255,255,255,.04);
  overflow: hidden;
}
.post-sticker{
  position:absolute;
  font-size: 54px;
  line-height: 1;
  user-select:none;
  filter: drop-shadow(0 6px 16px rgba(0,0,0,.35));
  animation: stickerPulse 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  transform-origin: center;
}
@keyframes stickerPulse{
  0%,100% { transform: scale(1) rotate(0deg); }
  50% { transform: scale(1.08) rotate(2deg); }
}

/* --- Your existing keyframes --- */
@keyframes emojiGlow{
  0% { filter: drop-shadow(0 5px 10px rgba(0,0,0,.26)) saturate(1); }
  50% { filter: drop-shadow(0 10px 18px rgba(0,0,0,.22)) saturate(1.25); }
  100% { filter: drop-shadow(0 5px 10px rgba(0,0,0,.26)) saturate(1); }
}
@keyframes emojiCrying{
  0%,100% { transform: translateX(0) translateY(0) scale(1); }
  25% { transform: translateX(-3px) translateY(2px) scale(1.02); }
  75% { transform: translateX(3px) translateY(2px) scale(1.02); }
}
@keyframes emojiLaughing{
  0%,100% { transform: translateY(0) rotateZ(0deg) scale(1); }
  25% { transform: translateY(-6px) rotateZ(-12deg) scale(1.1); }
  50% { transform: translateY(2px) rotateZ(0deg) scale(0.95); }
  75% { transform: translateY(-4px) rotateZ(12deg) scale(1.08); }
}
@keyframes emojiSpinning{
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.06); }
  100% { transform: rotate(360deg) scale(1); }
}
@keyframes emojiShocked{
  0%,100% { transform: translateX(0) translateY(0) scaleX(1); }
  10% { transform: translateX(-8px) translateY(-4px) scaleX(0.98); }
  20% { transform: translateX(8px) translateY(4px) scaleX(1.02); }
  30% { transform: translateX(-6px) translateY(-3px) scaleX(0.99); }
  40% { transform: translateX(6px) translateY(3px) scaleX(1.01); }
  50% { transform: translateX(-4px) translateY(-2px) scaleX(0.99); }
}
</style>
{% extends "base.html" %}

{% block body_class %}feed-page{% endblock %}

{% block content %}
<style>
  :root{
    --bg: #2a1204;
    --card: rgba(255,255,255,.12);
    --card2: rgba(255,255,255,.18);
    --text: rgba(255,255,255,.94);
    --muted: rgba(255,255,255,.70);
    --line: rgba(255,173,117,.34);
    --brand1:#ffb562;
    --brand2:#ff8226;
    --brand3:#ff4d00;
    --shadow: 0 18px 40px rgba(0,0,0,.45);
    --radius: 16px;
  }

  .vf-logo-probe {
    background-image: url("{{ url_for('VFlogo_clean.png') }}");
  }

  @keyframes logoGlowDrift {
    0% { opacity: 0.9; }
    50% { opacity: 1; }
    100% { opacity: 0.9; }
  }

  body.feed-page main{
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  body.feed-page .auth-wrap{
    width: 100%;
    max-width: none;
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--brand1, #ff9a3d) 16%, rgba(255,255,255,.08)),
      color-mix(in srgb, var(--bg, #0a0810) 82%, rgba(0,0,0,.45))
    );
    padding: 0 8px;
  }

  /* ===== VybeFlow Background (single logo + warm glass) ===== */
  body.feed-page{
    position: relative;
    min-height: 100vh;
    overflow-x: hidden;

    background:
      radial-gradient(1200px 680px at 50% 16%, rgba(255,150,60,.36), transparent 60%),
      radial-gradient(900px 620px at 12% 36%, rgba(255,96,0,.24), transparent 60%),
      radial-gradient(860px 640px at 88% 52%, rgba(255,180,90,.20), transparent 62%),
      linear-gradient(180deg, #2a1204 0%, #1a0b02 58%, #120601 100%);
    color: rgba(255,255,255,.92);
  }


  .feed-app{
    width: min(98vw, 1320px);
    max-width: 1320px;
    margin: 0 auto;
    padding: 12px 12px 36px;
    position: relative;
    z-index: 1;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    overflow: visible;
  }

  .feed-topbar{
    position: sticky; top: 0; z-index: 50;
    display:flex; align-items:center; gap:14px;
    padding: 10px 12px;
    background: rgba(28,12,4,.45);
    border: 1px solid rgba(255,160,90,.30);
    backdrop-filter: blur(18px) saturate(1.1);
    border-radius: var(--radius);
    box-shadow:
      0 10px 30px rgba(0,0,0,.35),
      0 0 30px rgba(255,106,0,.22);
  }

  .brand{
    display:flex; align-items:center; gap:10px;
    font-weight: 800; letter-spacing: .2px;
    text-transform: lowercase;
  }

  .brand-badge{
    width: 36px; height: 36px; border-radius: 12px;
    background: linear-gradient(135deg, var(--brand1), var(--brand2), var(--brand3));
    box-shadow: 0 10px 25px rgba(124,58,237,.28);
  }

  .brand span{
    font-size: 18px;
    background: linear-gradient(90deg, #fff, rgba(255,255,255,.72));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .vf-left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }

  .vf-brand{
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-weight: 800;
    letter-spacing: .2px;
  }

  .vf-logo-img{
    width: 38px;
    height: 38px;
    border-radius: 12px;
    object-fit: cover;
    box-shadow: 0 16px 32px rgba(255,122,24,.22);
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
  }

  .vf-search {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .vf-ico {
    color: var(--muted);
    font-size: 16px;
    line-height: 1;
  }

  .vf-search input {
    width: 100%;
  }

  .feed-search{
    flex: 1;
    height: 40px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.09);
    color: var(--text);
    padding: 0 14px;
    outline: none;
    transition: .2s ease;
  }
  .feed-search::placeholder{ color: rgba(255,255,255,.55); }
  .feed-search:focus{
    border-color: rgba(255,106,0,.72);
    box-shadow: 0 0 0 4px rgba(255,106,0,.20), 0 0 18px rgba(255,106,0,.24);
  }

  .topbar-tools {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .retro-switch {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
  }

  .retro-switch input {
    width: 40px;
    height: 22px;
    appearance: none;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.12);
    position: relative;
    cursor: pointer;
    transition: .2s ease;
  }

  .retro-switch input::before {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    transition: .2s ease;
  }

  .retro-switch input:checked {
    background: linear-gradient(90deg, var(--brand1), var(--brand2));
  }

  .retro-switch input:checked::before {
    transform: translateX(18px);
  }

  .feed-icons{ display:flex; align-items:center; gap:8px; }
  .icon-btn{
    width: 40px; height: 40px;
    display:grid; place-items:center;
    border-radius: 12px;
    border: 1px solid rgba(255,160,90,.24);
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
    backdrop-filter: blur(10px);
    color: var(--text);
    text-decoration:none;
    transition: transform .15s ease, background .15s ease, box-shadow .15s ease;
    position: relative;
  }
  .icon-btn:hover{
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(255,170,112,.35),
      0 0 26px rgba(255,106,0,.40),
      0 12px 26px rgba(0,0,0,.25);
  }
  .icon-badge{
    position:absolute; top:-6px; right:-6px;
    min-width: 18px; height: 18px;
    padding: 0 6px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--brand1), var(--brand2));
    border: 1px solid rgba(255,255,255,.18);
    color: white;
    font-size: 11px;
    display:flex; align-items:center; justify-content:center;
  }

  .feed-grid{
    display:grid;
    grid-template-columns: 260px minmax(0, 1fr) 260px;
    gap: 14px;
    margin-top: 12px;
    align-items: start;
    width: 100%;
  }
  @media (max-width: 1024px){
    .feed-grid{ grid-template-columns: 280px 1fr; }
    .right-panel{ display:none; }
  }
  @media (max-width: 780px){
    .feed-grid{ grid-template-columns: 1fr; }
    .left-panel{ display:none; }
  }

  .panel{
    border: 1px solid rgba(255,160,90,.30);
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(0,0,0,.10));
    border-radius: var(--radius);
    box-shadow:
      0 16px 40px rgba(0,0,0,.35),
      0 0 38px rgba(255,106,0,.25);
    backdrop-filter: blur(18px) saturate(1.1);
  }

  .left-panel, .right-panel{
    position: sticky; top: 76px;
    padding: 12px;
  }

  .menu-item{
    display:flex; align-items:center; gap:10px;
    padding: 10px 10px;
    border-radius: 14px;
    text-decoration:none;
    color: var(--text);
    transition: .15s ease;
    border: 1px solid transparent;
  }
  .menu-item:hover{
    background: rgba(255,255,255,.11);
    border-color: rgba(255,153,61,.30);
    transform: translateY(-1px);
  }
  .menu-item img{
    width: 34px; height: 34px; border-radius: 12px;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,.18);
  }

  .section-title{
    font-size: 13px;
    letter-spacing:.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 10px 8px 8px;
  }

  .center-panel{ display:flex; flex-direction:column; gap:14px; }

  .feed-composer{ padding: 12px; }
  .composer-top{ display:flex; gap:10px; align-items:center; }
  .avatar{
    width: 44px; height: 44px; border-radius: 16px;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,.18);
  }
  .composer-box{
    flex:1;
    display:flex; align-items:center;
    height: 44px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
    color: rgba(255,255,255,.78);
    text-decoration:none;
    transition: .15s ease;
  }
  .composer-box:hover{
    background: rgba(255,255,255,.10);
    color: rgba(255,255,255,.92);
  }
  .composer-actions{
    display:flex; gap:10px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--line);
  }
  .chip{
    flex:1;
    display:flex; align-items:center; justify-content:center;
    gap:8px;
    height: 38px;
    border-radius: 14px;
    border: 1px solid rgba(255,160,90,.24);
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
    backdrop-filter: blur(10px);
    color: var(--text);
    text-decoration:none;
    transition: .15s ease;
    font-size: 14px;
  }
  .chip:hover{
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(255,170,112,.35),
      0 0 26px rgba(255,106,0,.40),
      0 12px 26px rgba(0,0,0,.25);
  }

  .story-row{ padding: 12px; display:flex; gap:10px; overflow:auto; }
  .story-card{
    min-width: 88px;
    width: 88px;
    height: auto;
    border-radius: 999px;
    border: none;
    background: transparent;
    text-decoration:none;
    color: var(--text);
    position: static;
    overflow:hidden;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 0;
  }
  .story-card:hover{
    transform: translateY(-2px);
    box-shadow: none;
  }
  .story-media{
    width: 84px;
    height: 84px;
    border-radius: 999px;
    border: 2px solid rgba(255,255,255,.22);
    background:
      linear-gradient(135deg, rgba(255,154,61,.55), rgba(255,106,0,.40), rgba(255,72,0,.28)),
      radial-gradient(900px 300px at 0% 0%, rgba(255,255,255,.20), transparent 60%);
    filter: saturate(1.1);
    box-shadow: 0 0 18px rgba(255,106,0,.42);
  }
  .story-card p{
    position: static;
    margin:0;
    font-weight: 600;
    font-size: 12px;
    text-align: center;
    text-shadow: none;
  }
  .story-create .story-media{
    display:grid; place-items:center;
    font-size: 28px; font-weight: 900;
    background: linear-gradient(135deg, rgba(255,255,255,.14), rgba(255,255,255,.06));
  }

  .story-open {
    border: none;
    padding: 0;
    background: transparent;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
  }

  .story-inline-music {
    width: 88px;
    margin-top: 6px;
  }

  .story-inline-title {
    font-size: 10px;
    font-weight: 900;
    color: rgba(255,255,255,.85);
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .story-inline-audio {
    width: 100%;
    margin-top: 4px;
  }

  .story-modal-wrap {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    display: grid;
    place-items: center;
    z-index: 90;
  }

  .story-modal-wrap[hidden] {
    display: none;
  }

  .story-modal {
    width: min(94vw, 380px);
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,153,90,.32);
    background: linear-gradient(180deg, rgba(18,12,22,.95), rgba(8,8,12,.95));
    box-shadow: 0 16px 48px rgba(0,0,0,.55), 0 0 24px rgba(255,106,0,.30);
  }

  .story-progress {
    height: 4px;
    background: rgba(255,255,255,.2);
  }

  .story-progress span {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--brand1), var(--brand2));
    transition: width 4s linear;
  }

  .story-modal-media {
    height: 460px;
    background:
      linear-gradient(135deg, rgba(255,154,61,.62), rgba(255,106,0,.40), rgba(255,72,0,.30)),
      radial-gradient(900px 300px at 0% 0%, rgba(255,255,255,.22), transparent 60%);
  }

  .story-modal-media img,
  .story-modal-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .story-modal-meta {
    padding: 12px;
    color: #fff;
  }

  .story-modal-meta h4 {
    margin: 0 0 4px;
  }

  .story-modal-meta p {
    margin: 0;
    color: rgba(255,255,255,.85);
  }

  .story-modal-audio-wrap {
    margin-top: 10px;
  }

  .story-modal-audio {
    width: 100%;
    margin-top: 6px;
  }

  .story-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    font-size: 22px;
    color: #fff;
    background: rgba(0,0,0,.4);
    cursor: pointer;
    z-index: 91;
  }

  body.feed-page.retro-2011 {
    background: #e9ebee;
    color: #1d2129;
  }

  body.feed-page.retro-2011 .feed-app {
    max-width: 980px;
    padding-top: 0;
  }

  body.feed-page.retro-2011::before,
  body.feed-page.retro-2011::after {
    opacity: .28;
    pointer-events: none;
  }

  body.feed-page.retro-2011 .feed-topbar,
  body.feed-page.retro-2011 .panel {
    background: #fff;
    border-color: #d3d7df;
    box-shadow: 0 1px 2px rgba(0,0,0,.12);
    backdrop-filter: none;
  }

  body.feed-page.retro-2011 .feed-topbar {
    background: #3b5998;
    border-color: #2f477a;
    border-radius: 0;
    box-shadow: none;
  }

  body.feed-page.retro-2011 .vf-brand span,
  body.feed-page.retro-2011 .vf-ico,
  body.feed-page.retro-2011 .retro-switch {
    color: #fff;
    background: none;
    -webkit-text-fill-color: #fff;
  }

  body.feed-page.retro-2011 .feed-grid {
    grid-template-columns: 210px 1fr;
    gap: 10px;
  }

  body.feed-page.retro-2011 .right-panel {
    display: block;
  }

  body.feed-page.retro-2011 .left-panel,
  body.feed-page.retro-2011 .feed-composer,
  body.feed-page.retro-2011 .post-card {
    border-radius: 2px;
  }

  body.feed-page.retro-2011 .story-card {
    min-width: 95px;
    height: 135px;
    border-radius: 8px;
  }

  body.feed-page.retro-2011 .post-card {
    border-radius: 4px;
  }

  body.feed-page.retro-2011 .brand span,
  body.feed-page.retro-2011 .menu-item,
  body.feed-page.retro-2011 .chip,
  body.feed-page.retro-2011 .action-btn,
  body.feed-page.retro-2011 .trend-chip,
  body.feed-page.retro-2011 .post-body,
  body.feed-page.retro-2011 .section-title,
  body.feed-page.retro-2011 .feed-search,
  body.feed-page.retro-2011 .icon-btn {
    color: #1d2129;
  }

  body.feed-page.retro-2011 .feed-search,
  body.feed-page.retro-2011 .chip,
  body.feed-page.retro-2011 .action-btn,
  body.feed-page.retro-2011 .trend-chip,
  body.feed-page.retro-2011 .icon-btn {
    background: #f5f6f7;
    border-color: #d3d7df;
  }

  .post-card{ padding: 12px; }
  .post-head{ display:flex; gap:10px; align-items:center; }
  .post-head h3{ margin:0; font-size: 15px; }
  .post-head small{ color: var(--muted); }
  .post-body{ margin: 10px 0 12px; color: rgba(255,255,255,.86); line-height: 1.35; }

  .vf-react{
    margin-top: 10px;
    display:flex;
    align-items:center;
    gap:10px;
    position: relative;
  }
  .vf-react-btn,
  .vf-re{
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
    color: var(--text);
    cursor: pointer;
  }
  .vf-react-btn{
    height: 36px;
    padding: 0 12px;
    border-radius: 999px;
    font-weight: 800;
  }
  .vf-react-pop{
    position: absolute;
    left: 0;
    top: -44px;
    display:flex;
    align-items:center;
    gap:6px;
    padding: 6px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(32,14,8,.88);
    backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: .16s ease;
    z-index: 4;
  }
  .vf-react:hover .vf-react-pop,
  .vf-react:focus-within .vf-react-pop{
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  .vf-re{
    width: 32px;
    height: 32px;
    border-radius: 999px;
    font-size: 17px;
    display:grid;
    place-items:center;
    line-height: 1;
  }
  .vf-re:hover{ transform: translateY(-1px) scale(1.05); }
  .vf-react-count{
    display:flex;
    align-items:center;
    gap:6px;
    min-height: 34px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
    color: var(--muted);
    font-weight: 700;
  }
  .vf-react-emoji{ font-size: 15px; }

  .post-meta{
    display:flex; justify-content:space-between; align-items:center;
    color: var(--muted);
    font-size: 13px;
    padding: 8px 2px 10px;
    border-top: 1px solid transparent;
  }
  .reactions{
    display:flex; gap:8px; align-items:center; flex-wrap:wrap;
  }
  .reaction-pill{
    display:flex; gap:6px; align-items:center;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
  }

  .post-actions{
    display:flex; gap:10px;
    border-top: 1px solid var(--line);
    padding-top: 10px;
  }
  .action-btn{
    flex:1;
    height: 38px;
    border-radius: 14px;
    display:flex; align-items:center; justify-content:center;
    gap:8px;
    border: 1px solid rgba(255,160,90,.24);
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
    backdrop-filter: blur(10px);
    color: var(--text);
    text-decoration:none;
    transition: .15s ease;
    font-weight: 650;
  }
  .action-btn:hover{
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(255,170,112,.35),
      0 0 26px rgba(255,106,0,.40),
      0 12px 26px rgba(0,0,0,.25);
  }

  .trend-chip{
    display:inline-flex; align-items:center; gap:8px;
    padding: 8px 10px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
    color: var(--text);
    text-decoration:none;
    margin: 6px 6px 0 0;
    transition: .15s ease;
    font-size: 13px;
  }
  .trend-chip:hover{
    background: rgba(255,255,255,.10);
    border-color: rgba(255,106,0,.38);
    transform: translateY(-1px);
  }

  .mini-card{
    border: 1px solid var(--line);
    background: rgba(255,255,255,.06);
    border-radius: 16px;
    padding: 10px;
    margin-top: 10px;
  }

  .creator-lab { padding: 12px; }
  .lab-input, .lab-textarea {
    width: 100%;
    margin-top: 8px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.07);
    color: var(--text);
    padding: 10px;
    box-sizing: border-box;
  }
  .lab-textarea { min-height: 92px; resize: vertical; }
  .emoji-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; align-items: center; }
  .emoji-row button {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    outline: none;
    display: inline-block;
  }
  .emoji-btn {
    border: 1px solid var(--line);
    background: rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 4px 8px;
    cursor: pointer;
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    user-select: none;
  }
  .emoji-toolbar { display: flex; gap: 8px; margin-bottom: 8px; }
  .mvp-pill-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .mvp-pill {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 12px;
    background: rgba(255,255,255,.08);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 0 18px rgba(255,106,0,.18);
  }
  .mvp-pill:hover { transform: translateY(-1px); box-shadow: 0 0 0 1px rgba(255,173,117,.30), 0 0 24px rgba(255,106,0,.35); }
  .emoji-tab {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255,255,255,.08);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    font-weight: 800;
  }
  .emoji-tab.active { border-color: rgba(255,154,61,.9); box-shadow: 0 0 0 2px rgba(255,154,61,.22); }
  .emoji-panel {
    margin-top: 8px;
    padding: 10px;
    border-radius: 12px;
    border: 1px dashed var(--line);
    background: rgba(0,0,0,.18);
  }
  .sticker-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 6px;
    margin-bottom: 8px;
  }
  .sticker-item {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255,255,255,.08);
    cursor: pointer;
    min-height: 38px;
    display: grid;
    place-items: center;
    font-size: 22px;
    transition: transform .16s ease, box-shadow .16s ease;
  }
  .sticker-item:hover { transform: translateY(-2px) scale(1.08); box-shadow: 0 0 16px rgba(255,106,0,.22); }
  .emoji-btn.emoji-rich {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    outline: none;
    display: inline-block;
    cursor: pointer;
    font-size: 48px;
    line-height: 1;
    position: relative;
    animation: emojiGlow 2.8s ease-in-out infinite;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,.26));
    text-shadow: 0 0 12px color-mix(in srgb, var(--brand2, #ff7a1f) 60%, transparent);
    transition: transform .18s ease, filter .18s ease;
    user-select: none;
    -webkit-appearance: none;
    appearance: none;
    box-shadow: none;
  }
  .emoji-btn.emoji-rich[data-emotion="crying"],
  .emoji-btn.emoji-rich[data-emotion="sad"]{
    animation: emojiGlow 2.8s ease-in-out infinite, emojiCrying 3.2s ease-in-out infinite;
  }
  .emoji-btn.emoji-rich[data-emotion="laughing"],
  .emoji-btn.emoji-rich[data-emotion="joy"]{
    animation: emojiGlow 2.8s ease-in-out infinite, emojiLaughing 2.8s ease-in-out infinite;
  }
  .emoji-btn.emoji-rich[data-emotion="fire"]{
    animation: emojiGlow 2.8s ease-in-out infinite, emojiSpinning 2.4s linear infinite;
  }
  .emoji-btn.emoji-rich[data-emotion="shocked"]{
    animation: emojiGlow 2.8s ease-in-out infinite, emojiShocked 0.5s ease-in-out infinite;
  }
  .emoji-btn.emoji-rich:nth-child(3n):not([data-emotion]){
    animation: emojiGlow 2.8s ease-in-out infinite, emojiWobble 2.4s ease-in-out infinite;
  }
  .emoji-btn.emoji-rich:nth-child(4n):not([data-emotion]){
    animation: emojiGlow 2.8s ease-in-out infinite, emojiBounce 2.8s ease-in-out infinite;
  }
  .emoji-btn.emoji-rich:hover {
    transform: scale(1.15);
    filter: drop-shadow(0 8px 16px rgba(0,0,0,.34));
  }
  .emoji-stage {
    position: relative;
    width: 100%;
    height: 160px;
    margin-top: 10px;
    border-radius: 12px;
    border: 1px dashed var(--line);
    background: rgba(255,255,255,.04);
    overflow: hidden;
  }
  .emoji-stage-note { margin-top: 6px; color: var(--muted); font-size: 12px; }
  .emoji-sticker {
    position: absolute;
    font-size: 48px;
    cursor: grab;
    user-select: none;
    touch-action: none;
    animation: stickerPulse 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,.34));
  }
  @keyframes stickerPulse{
    0%, 100% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.08) rotate(2deg); }
  }
  .emoji-3d {
    display: inline-block;
    transform-style: preserve-3d;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,.32));
    animation: emoji3dGlow 3.4s ease-in-out infinite;
    text-shadow: 0 0 12px color-mix(in srgb, var(--brand1, #ff9a3d) 55%, transparent);
  }
  .emoji-3d:hover {
    animation: emojiFloat3d 1.2s ease-in-out;
  }
  .emoji-sticker:active { cursor: grabbing; }
  .emoji-sticker.active{ animation: stickerSelected 0.3s ease; }
  @keyframes stickerSelected{
    0% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.2) rotate(-8deg); }
    100% { transform: scale(1.08) rotate(0deg); }
  }
  @keyframes emojiPulse {
    0% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-2px) scale(1.06); }
    100% { transform: translateY(0) scale(1); }
  }
  @keyframes emojiFloat {
    0% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
    100% { transform: translateY(0); }
  }
  @keyframes emojiFloat3d {
    0% { transform: perspective(700px) translateY(0) rotateX(0deg) rotateY(0deg); }
    50% { transform: perspective(700px) translateY(-4px) rotateX(10deg) rotateY(-8deg); }
    100% { transform: perspective(700px) translateY(0) rotateX(0deg) rotateY(0deg); }
  }
  @keyframes emojiGlow {
    0% {
      filter: drop-shadow(0 5px 10px rgba(0,0,0,.26)) saturate(1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.20), 0 8px 16px rgba(0,0,0,.22), 0 0 18px color-mix(in srgb, var(--brand2, #ff7a1f) 40%, transparent);
    }
    50% {
      filter: drop-shadow(0 10px 18px rgba(0,0,0,.22)) saturate(1.25);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.24), 0 10px 20px rgba(0,0,0,.24), 0 0 calc(24px + (var(--vf-glow-alpha, 0.18) * 40px)) color-mix(in srgb, var(--brand2, #ff7a1f) 70%, transparent);
    }
    100% {
      filter: drop-shadow(0 5px 10px rgba(0,0,0,.26)) saturate(1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.20), 0 8px 16px rgba(0,0,0,.22), 0 0 18px color-mix(in srgb, var(--brand2, #ff7a1f) 40%, transparent);
    }
  }
  @keyframes emoji3dGlow {
    0% { filter: drop-shadow(0 4px 10px rgba(0,0,0,.32)) saturate(1); }
    50% { filter: drop-shadow(0 10px 20px color-mix(in srgb, var(--brand1, #ff9a3d) 55%, transparent)) saturate(1.3); }
    100% { filter: drop-shadow(0 4px 10px rgba(0,0,0,.32)) saturate(1); }
  }
  @keyframes emojiWobble{
    0% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-2px) rotate(-6deg); }
    50% { transform: translateY(0) rotate(6deg); }
    75% { transform: translateY(-1px) rotate(-4deg); }
    100% { transform: translateY(0) rotate(0deg); }
  }
  @keyframes emojiBounce{
    0% { transform: translateY(0) scale(1); }
    30% { transform: translateY(-4px) scale(1.06); }
    50% { transform: translateY(0) scale(1); }
    70% { transform: translateY(-2px) scale(1.03); }
    100% { transform: translateY(0) scale(1); }
  }
  @keyframes emojiCrying{
    0%, 100% { transform: translateX(0) translateY(0) scale(1); }
    25% { transform: translateX(-3px) translateY(2px) scale(1.02); }
    50% { transform: translateX(0) translateY(0) scale(1); }
    75% { transform: translateX(3px) translateY(2px) scale(1.02); }
  }
  @keyframes emojiLaughing{
    0%, 100% { transform: translateY(0) rotateZ(0deg) scale(1); }
    25% { transform: translateY(-6px) rotateZ(-12deg) scale(1.1); }
    50% { transform: translateY(2px) rotateZ(0deg) scale(0.95); }
    75% { transform: translateY(-4px) rotateZ(12deg) scale(1.08); }
  }
  @keyframes emojiSpinning{
    0% { transform: rotate(0deg) scale(1); }
    50% { transform: rotate(180deg) scale(1.06); }
    100% { transform: rotate(360deg) scale(1); }
  }
  @keyframes emojiShocked{
    0%, 100% { transform: translateX(0) translateY(0) scaleX(1); }
    10% { transform: translateX(-8px) translateY(-4px) scaleX(0.98); }
    20% { transform: translateX(8px) translateY(4px) scaleX(1.02); }
    30% { transform: translateX(-6px) translateY(-3px) scaleX(0.99); }
    40% { transform: translateX(6px) translateY(3px) scaleX(1.01); }
    50% { transform: translateX(-4px) translateY(-2px) scaleX(0.99); }
  }
  .lab-actions { display: flex; gap: 10px; margin-top: 10px; }
  .lab-btn {
    border: none;
    border-radius: 999px;
    padding: 10px 14px;
    color: #fff;
    background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
    border: 1px solid rgba(255,160,90,.24);
    backdrop-filter: blur(10px);
    cursor: pointer;
    font-weight: 700;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 0 22px rgba(255,106,0,.16);
  }

  body.feed-page .action-btn,
  body.feed-page .chip,
  body.feed-page .menu-item,
  body.feed-page .trend-chip,
  body.feed-page .icon-btn,
  body.feed-page .lab-btn,
  body.feed-page button {
    box-shadow: 0 0 0 1px rgba(255,173,117,.26), 0 0 18px rgba(255,106,0,.32);
  }

  body.feed-page button:hover,
  body.feed-page .chip:hover,
  body.feed-page .icon-btn:hover,
  body.feed-page .menu-item:hover,
  body.feed-page .action-btn:hover,
  body.feed-page .trend-chip:hover,
  body.feed-page .lab-btn:hover,
  body.feed-page .emoji-btn:hover,
  body.feed-page .gif-item:hover,
  body.feed-page .story-card:hover {
    box-shadow: 0 0 0 1px rgba(255,173,117,.35), 0 0 24px rgba(255,106,0,.52), 0 12px 24px rgba(0,0,0,.24);
  }
  .gif-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; margin-top: 10px; }
  .gif-item {
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255,255,255,.06);
    cursor: pointer;
  }
  .gif-item img { width: 100%; height: 96px; object-fit: cover; display: block; }
  .gif-empty { grid-column: 1 / -1; padding: 10px; text-align: center; color: var(--muted); font-size: 12px; }
  .feed-live-posts { margin-top: 12px; display: grid; gap: 10px; }
  .live-post { border: 1px solid var(--line); border-radius: 12px; padding: 10px; background: rgba(255,255,255,.06); }
  .live-post img { width: 100%; max-height: 220px; object-fit: cover; border-radius: 10px; margin-top: 8px; }
  .live-post video { width: 100%; max-height: 260px; object-fit: cover; border-radius: 10px; margin-top: 8px; background: #000; }

  .game-card { padding: 12px; }
  .game-hud { display: flex; justify-content: space-between; margin-bottom: 8px; color: var(--muted); }

  .ai-card { padding: 12px; }
  .ai-log { border: 1px solid var(--line); border-radius: 10px; min-height: 80px; padding: 10px; background: rgba(255,255,255,.04); }

  /* ===== Reels Rail ===== */
  .reels-rail{ padding: 12px; }
  .reels-head{
    display:flex; align-items:flex-end; justify-content:space-between; gap:12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }
  .reels-title{ font-weight: 1000; letter-spacing:.2px; font-size: 16px; }
  .reels-sub{ font-size: 12px; color: var(--muted); margin-top: 2px; }
  .reels-actions{ display:flex; gap:8px; flex-wrap:wrap; }
  .reels-chip{
    height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.06);
    color: var(--text);
    font-weight: 950;
    cursor:pointer;
    text-decoration:none;
    display:inline-flex; align-items:center; justify-content:center;
    transition: .15s ease;
  }
  .reels-chip:hover{
    transform: translateY(-1px);
    border-color: rgba(255,106,0,.45);
    box-shadow: 0 0 0 4px rgba(255,106,0,.12), 0 12px 26px rgba(0,0,0,.25);
  }

  .reels-chip.active-sort{
    border-color: rgba(255,122,24,.55);
    box-shadow: 0 0 0 3px rgba(255,122,24,.16), 0 0 20px rgba(255,122,24,.30);
  }

  .reels-row{
    margin-top: 12px;
    display:flex;
    gap: 12px;
    overflow-x:auto;
    overflow-y:hidden;
    scroll-snap-type:x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 6px;
  }
  .reels-row::-webkit-scrollbar{ height: 8px; }
  .reels-row::-webkit-scrollbar-thumb{
    background: rgba(255,255,255,.14);
    border-radius: 999px;
  }

  /* Reel tile */
  .reel-card{
    flex: 0 0 160px;
    height: 260px;
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.05);
    box-shadow: 0 20px 55px rgba(0,0,0,.55), 0 0 40px rgba(255,106,0,.18);
    overflow:hidden;
    position:relative;
    scroll-snap-align: start;
    cursor:pointer;
    padding: 0;
    transform: translateZ(0);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }

  .reel-card::before{
    content:"";
    position:absolute; inset:-60px;
    background:
      radial-gradient(700px 260px at 20% 15%, rgba(255,177,95,.28), transparent 60%),
      radial-gradient(700px 260px at 90% 80%, rgba(255,79,0,.18), transparent 60%);
    opacity: .95;
    pointer-events:none;
  }

  .reel-card::after{
    content:"";
    position:absolute; inset:0;
    background: linear-gradient(180deg, rgba(0,0,0,.05), rgba(0,0,0,.75));
    pointer-events:none;
  }

  .reel-card:hover{
    transform: translateY(-4px) rotate(-.35deg);
    border-color: rgba(255,106,0,.35);
    box-shadow:
      0 26px 70px rgba(0,0,0,.65),
      0 0 55px rgba(255,106,0,.22);
  }

  /* Media layer (cover image) */
  .reel-media{
    position:absolute; inset:0;
    background-size: cover;
    background-position:center;
    background-repeat:no-repeat;
    filter: saturate(1.15) contrast(1.08);
  }
  .reel-media.demo{
    background:
      radial-gradient(700px 260px at 20% 20%, rgba(255,122,24,.45), transparent 60%),
      radial-gradient(700px 260px at 85% 70%, rgba(255,79,0,.20), transparent 60%),
      linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.02));
  }

  /* Glass top/bottom overlays */
  .reel-glass-top,
  .reel-glass-bot{
    position:absolute;
    left: 10px;
    right: 10px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    z-index: 3;
    padding: 8px 10px;
    border-radius: 16px;
    background: rgba(0,0,0,.28);
    border: 1px solid rgba(255,255,255,.14);
    backdrop-filter: blur(14px);
  }

  .reel-glass-top{ top: 10px; }
  .reel-glass-bot{ bottom: 10px; }

  .reel-badges{ display:flex; gap:6px; flex-wrap:wrap; }
  .reel-pill{
    font-size: 11px;
    font-weight: 1000;
    letter-spacing:.08em;
    padding: 5px 8px;
    border-radius: 999px;
    color: rgba(255,255,255,.95);
    background: linear-gradient(90deg, rgba(255,177,95,.35), rgba(255,79,0,.22));
    border: 1px solid rgba(255,255,255,.12);
  }
  .reel-pill.ghost{
    background: rgba(255,255,255,.08);
    color: rgba(255,255,255,.88);
  }

  .reel-heat{
    display:none;
    position:absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    padding: 4px 8px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 1000;
    letter-spacing:.08em;
    color:#fff;
    background: linear-gradient(90deg, rgba(255,177,95,.58), rgba(255,79,0,.48));
    border: 1px solid rgba(255,255,255,.18);
    box-shadow: 0 10px 18px rgba(0,0,0,.32), 0 0 22px rgba(255,122,24,.25);
  }

  .reel-card.hot .reel-heat{ display:inline-flex; align-items:center; gap:4px; }

  .reel-hover-overlay{
    position:absolute;
    left: 10px;
    right: 10px;
    bottom: 56px;
    display:flex;
    gap: 8px;
    z-index: 4;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: .18s ease;
  }

  .reel-card:hover .reel-hover-overlay,
  .reel-card:focus-within .reel-hover-overlay{
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .reel-overlay-btn{
    flex:1;
    height: 32px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.16);
    background: rgba(0,0,0,.32);
    color:#fff;
    font-weight: 900;
    font-size: 12px;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:6px;
    cursor:pointer;
    backdrop-filter: blur(10px);
  }

  .reel-overlay-btn:hover{
    border-color: rgba(255,122,24,.58);
    box-shadow: 0 0 0 3px rgba(255,122,24,.14), 0 0 18px rgba(255,122,24,.26);
  }

  .reel-play{
    width: 34px; height: 34px;
    border-radius: 14px;
    display:grid; place-items:center;
    background: linear-gradient(135deg, rgba(255,177,95,.45), rgba(255,79,0,.22));
    border: 1px solid rgba(255,255,255,.16);
    font-weight: 1000;
    box-shadow: 0 12px 26px rgba(0,0,0,.35), 0 0 22px rgba(255,106,0,.25);
  }

  /* Bottom meta */
  .reel-avatar{
    width: 30px; height: 30px;
    border-radius: 12px;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,.18);
  }
  .reel-user{
    flex:1;
    text-align:left;
    font-weight: 950;
    font-size: 12px;
    white-space: nowrap;
    overflow:hidden;
    text-overflow: ellipsis;
  }
  .reel-flex{
    display:flex; align-items:center; gap:6px;
    font-weight: 1000;
    font-size: 12px;
  }
  .reel-flame{ filter: drop-shadow(0 6px 10px rgba(0,0,0,.35)); }
  .reel-flex-num{
    min-width: 18px;
    text-align:right;
  }

  /* Flex FX: a neon вАЬedgeвАЭ that pulses */
  .reel-card.vybe-hot{
    animation: vybeEdgePulse 1.8s ease-in-out infinite;
  }
  @keyframes vybeEdgePulse{
    0% { box-shadow: 0 22px 60px rgba(0,0,0,.60), 0 0 40px rgba(255,106,0,.18); }
    50% { box-shadow: 0 26px 75px rgba(0,0,0,.68), 0 0 70px rgba(255,106,0,.30); }
    100% { box-shadow: 0 22px 60px rgba(0,0,0,.60), 0 0 40px rgba(255,106,0,.18); }
  }

  /* ===== Fullscreen Reel Viewer ===== */
  .reel-viewer{
    position: fixed;
    inset: 0;
    z-index: 120;
    background: rgba(0,0,0,.86);
    display:grid;
    place-items:center;
  }
  .reel-viewer[hidden]{ display:none; }

  .reel-view-close{
    position:absolute;
    top: 16px;
    left: 16px;
    width: 42px; height: 42px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.92);
    font-weight: 1000;
    cursor:pointer;
    backdrop-filter: blur(14px);
  }

  .reel-view-stage{
    width: min(92vw, 420px);
    aspect-ratio: 9 / 16;
    border-radius: 22px;
    overflow:hidden;
    border: 1px solid rgba(255,255,255,.14);
    box-shadow: 0 22px 80px rgba(0,0,0,.75), 0 0 65px rgba(255,106,0,.22);
    position: relative;
    background: #000;
  }

  .reel-view-video{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display:block;
  }

  .reel-view-hud{
    position:absolute;
    inset: 0;
    pointer-events:none;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    padding: 14px;
    background: linear-gradient(180deg, rgba(0,0,0,.15), rgba(0,0,0,.55));
  }

  .reel-view-user{
    pointer-events:none;
    display:flex;
    align-items:center;
    gap:10px;
  }
  .reel-view-avatar{
    width: 40px; height: 40px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,.16);
    object-fit: cover;
  }
  .reel-view-handle{ font-weight: 1000; }
  .reel-view-sub{ font-size: 12px; color: rgba(255,255,255,.70); }

  .reel-view-actions{
    pointer-events:auto;
    align-self:flex-end;
    display:flex;
    flex-direction:column;
    gap: 10px;
  }
  .rv-btn{
    width: 46px; height: 46px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.95);
    font-size: 18px;
    cursor:pointer;
    backdrop-filter: blur(14px);
    box-shadow: 0 0 0 1px rgba(255,173,117,.26), 0 0 18px rgba(255,106,0,.32);
  }
  .rv-btn:hover{
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px rgba(255,173,117,.35), 0 0 30px rgba(255,106,0,.55), 0 12px 24px rgba(0,0,0,.24);
  }

  .reel-view-hint{
    position:absolute;
    left:50%;
    transform: translateX(-50%);
    bottom: 14px;
    font-size: 11px;
    color: rgba(255,255,255,.76);
    background: rgba(0,0,0,.32);
    border: 1px solid rgba(255,255,255,.16);
    padding: 5px 10px;
    border-radius: 999px;
    z-index: 5;
    backdrop-filter: blur(10px);
    pointer-events:none;
  }

  /* ===== REELS RAIL ===== */

  .vf-reels-rail{
    padding:12px;
    border-radius:18px;
    border:1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.05);
    backdrop-filter: blur(20px);
  }

  .vf-reels-head{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:10px;
  }

  .vf-reels-title{
    font-weight:900;
    font-size:16px;
  }

  /* ===== GLASS BUTTONS ===== */

  .vf-glass-btn{
    padding:8px 14px;
    border-radius:999px;
    text-decoration:none;
    font-weight:700;
    color:white;
    border:1px solid rgba(255,255,255,.18);
    background: rgba(255,255,255,.08);
    backdrop-filter: blur(14px);
    transition:.2s ease;
  }

  .vf-glass-btn:hover{
    border-color: rgba(255,122,24,.45);
    box-shadow:
      0 0 0 3px rgba(255,122,24,.15),
      0 0 22px rgba(255,122,24,.35);
    transform: translateY(-1px);
  }

  /* ===== REELS ROW ===== */

  .vf-reels-row{
    display:flex;
    gap:12px;
    overflow-x:auto;
    scroll-snap-type:x mandatory;
    padding-bottom:4px;
  }

  .vf-reels-row::-webkit-scrollbar{
    height:8px;
  }

  .vf-reels-row::-webkit-scrollbar-thumb{
    background: rgba(255,255,255,.15);
    border-radius:999px;
  }

  /* ===== REEL CARD ===== */

  .vf-reel-card{
    position:relative;
    flex:0 0 150px;
    height:260px;
    border-radius:18px;
    overflow:hidden;
    scroll-snap-align:start;
    border:1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.04);
    transition:.2s ease;
  }

  .vf-reel-card:hover{
    transform: translateY(-3px);
    border-color: rgba(255,122,24,.45);
    box-shadow:
      0 0 0 3px rgba(255,122,24,.12),
      0 0 35px rgba(255,122,24,.35);
  }

  /* ===== MEDIA ===== */

  .vf-reel-media{
    position:absolute;
    inset:0;
    background-size:cover;
    background-position:center;
    filter: contrast(1.05) saturate(1.1);
  }

  /* ===== OVERLAY ===== */

  .vf-reel-overlay{
    position:absolute;
    inset:0;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    padding:10px;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,.65));
    color:white;
  }

  .vf-reel-play{
    width:36px;
    height:36px;
    border-radius:50%;
    background: rgba(0,0,0,.45);
    display:grid;
    place-items:center;
    font-weight:900;
    backdrop-filter: blur(10px);
  }

  .vf-reel-user{
    font-size:12px;
    font-weight:800;
  }

  @media (max-width: 560px){
    .reel-card{ flex-basis: 148px; height: 244px; }
  }

  @keyframes floaty {
    0% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
    100% { transform: translateY(0); }
  }
  .brand-badge{ animation: floaty 2.6s ease-in-out infinite; }

  .vf-create{
    position: fixed;
    inset: 0;
    background: #0b0b0e;
    color: #fff;
    z-index: 9999;
    display:flex;
    flex-direction:column;
  }

  .vf-create[hidden]{
    display: none;
  }

  .vf-create-top{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 14px 14px 8px;
  }
  .vf-x, .vf-gear{
    width: 38px; height: 38px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,.12);
    background: rgba(255,255,255,.06);
    color:#fff;
    font-size: 18px;
    cursor:pointer;
  }
  .vf-title{ font-weight: 900; letter-spacing:.2px; }

  .vf-create-actions{
    display:flex; gap:10px;
    padding: 6px 14px 10px;
  }
  .vf-pill{
    height: 34px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color:#fff;
    font-weight: 900;
    cursor:pointer;
  }

  .vf-create-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding: 6px 14px 10px;
  }
  .vf-row-left{ display:flex; align-items:center; gap:8px; color: rgba(255,255,255,.9); }
  .vf-row-label{ font-weight: 900; }
  .vf-select{
    height: 32px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color:#fff;
    font-weight: 900;
    cursor:pointer;
  }

  .vf-grid{
    flex: 1;
    padding: 0 10px 10px;
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
    overflow:auto;
  }

  .vf-tile{
    position: relative;
    border: 0;
    border-radius: 10px;
    overflow:hidden;
    background: rgba(255,255,255,.06);
    cursor:pointer;
    aspect-ratio: 1 / 1;
  }
  .vf-tile img, .vf-tile video{
    width:100%; height:100%;
    object-fit: cover;
    display:block;
  }
  .vf-badge{
    position:absolute;
    right: 8px; top: 8px;
    width: 28px; height: 28px;
    border-radius: 10px;
    display:grid; place-items:center;
    background: rgba(0,0,0,.35);
    border: 1px solid rgba(255,255,255,.14);
    backdrop-filter: blur(10px);
  }

  .vf-camera{
    display:grid;
    place-items:center;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.10);
  }
  .vf-cam-icon{ font-size: 22px; }

  .vf-empty{
    grid-column: 1 / -1;
    padding: 14px;
    color: rgba(255,255,255,.65);
    border: 1px dashed rgba(255,255,255,.18);
    border-radius: 12px;
    background: rgba(255,255,255,.04);
  }

  .vf-tabs{
    display:flex;
    gap: 14px;
    justify-content:center;
    padding: 10px 10px 14px;
    border-top: 1px solid rgba(255,255,255,.10);
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(14px);
  }
  .vf-tab{
    border:0;
    background: transparent;
    color: rgba(255,255,255,.55);
    font-weight: 1000;
    letter-spacing:.14em;
    cursor:pointer;
  }
  .vf-tab.active{ color:#fff; }

  .post-card{
    padding: 14px;
    border-radius: 18px;
  }
  .center-panel{ position: relative; }
  .center-panel::before{
    content:"";
    position:absolute;
    inset:0;
    background-image: url("{{ url_for('VFlogo_clean.png') }}");
    background-repeat: no-repeat;
    background-position: center 140px;
    background-size: 280px auto;
    opacity: .06;
    pointer-events: none;
    z-index: 0;
  }
  .center-panel > *{ position: relative; z-index: 1; }

  .post-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 12px;
  }

  .post-user{
    display:flex;
    align-items:center;
    gap: 10px;
    min-width: 0;
  }

  .post-user .meta{
    display:flex;
    flex-direction:column;
    min-width:0;
  }

  .post-user .name{
    font-weight: 900;
    line-height: 1.1;
    white-space: nowrap;
    overflow:hidden;
    text-overflow: ellipsis;
  }

  .post-user .sub{
    font-size: 12px;
    color: rgba(255,255,255,.68);
    display:flex;
    gap: 8px;
    align-items:center;
  }

  .post-menu{
    width: 40px;
    height: 40px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.90);
    cursor:pointer;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 0 20px rgba(255,106,0,.18);
  }

  .post-body{
    margin-top: 10px;
    color: rgba(255,255,255,.88);
    line-height: 1.45;
    font-size: 15px;
  }

  .post-media{
    margin-top: 10px;
    border-radius: 16px;
    overflow:hidden;
    border: 1px solid var(--line);
    background: rgba(0,0,0,.25);
    box-shadow: 0 0 28px rgba(255,106,0,.14);
  }

  .post-media img,
  .post-media video{
    width:100%;
    max-height: 520px;
    object-fit: cover;
    display:block;
  }

  .post-stats{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top: 10px;
    color: rgba(255,255,255,.70);
    font-size: 13px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255,173,117,.18);
  }

  .post-actions{
    display:flex;
    gap:10px;
    margin-top: 10px;
  }

  .gloss-btn{
    flex: 1;
    height: 40px;
    border-radius: 14px;
    border: 1px solid rgba(255,173,117,.22);
    background: linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.04));
    backdrop-filter: blur(10px);
    color: rgba(255,255,255,.92);
    font-weight: 850;
    cursor:pointer;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 0 22px rgba(255,106,0,.16);
  }

  .gloss-btn:hover{
    background: linear-gradient(180deg, rgba(255,255,255,.14), rgba(255,255,255,.06));
    box-shadow: 0 0 0 1px rgba(255,173,117,.30), 0 0 30px rgba(255,106,0,.26);
  }

  .mvp-post-panel { padding: 12px; display: grid; gap: 10px; }
  .mvp-meta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    align-items: start;
  }
  .mvp-label { font-size: 12px; color: var(--muted); display: block; margin-bottom: 6px; }
  .mvp-share-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .mvp-share-chip {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(255,255,255,.06);
    color: var(--text);
    font-size: 12px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }
  .mvp-share-chip input { accent-color: var(--brand2); }
  .mvp-row { display: grid; grid-template-columns: 1fr 170px 150px 120px auto; gap: 8px; }
  .mvp-input, .mvp-select, .mvp-btn {
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(255,255,255,.08);
    color: var(--text);
    padding: 10px;
  }
  .mvp-btn { cursor: pointer; font-weight: 800; white-space: nowrap; }
  .mvp-feedback { font-size: 12px; color: var(--muted); min-height: 16px; }
  .mvp-posts { display: grid; gap: 12px; }
  .mvp-card { padding: 12px; border-radius: 16px; border: 1px solid var(--line); position: relative; overflow: hidden; }
  .mvp-card.bg-default { background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(0,0,0,.12)); }
  .mvp-card.bg-sunset { background: linear-gradient(135deg, rgba(255,140,40,.35), rgba(255,90,0,.20), rgba(0,0,0,.25)); }
  .mvp-card.bg-neon { background: linear-gradient(135deg, rgba(255,90,0,.28), rgba(145,85,255,.22), rgba(0,0,0,.24)); }
  .mvp-card.bg-glass { background: linear-gradient(135deg, rgba(255,255,255,.14), rgba(255,255,255,.05)); }
  .mvp-card.bg-custom { background: rgba(255,255,255,.08); }
  .mvp-stickers {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .mvp-sticker {
    position: absolute;
    font-size: 26px;
    transform-style: preserve-3d;
    animation: emojiFloat3d 2.4s ease-in-out infinite;
    pointer-events: auto;
    user-select: none;
  }
  .mvp-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .mvp-user { display: flex; align-items: center; gap: 10px; }
  .mvp-avatar { width: 38px; height: 38px; border-radius: 12px; object-fit: cover; border: 1px solid rgba(255,255,255,.2); }
  .mvp-title { font-weight: 900; }
  .mvp-sub { font-size: 12px; color: var(--muted); }
  .mvp-caption { margin-top: 8px; white-space: pre-wrap; }
  .mvp-media { margin-top: 10px; border-radius: 12px; overflow: hidden; border: 1px solid var(--line); }
  .mvp-media img, .mvp-media video { width: 100%; max-height: 420px; object-fit: cover; display: block; }
  .mvp-actions { margin-top: 10px; display: flex; gap: 8px; }
  .mvp-chip { border: 1px solid var(--line); border-radius: 999px; background: rgba(255,255,255,.08); color: var(--text); padding: 7px 10px; cursor: pointer; font-size: 12px; }
  .mvp-comments { margin-top: 10px; display: grid; gap: 8px; }
  .mvp-comment { border: 1px solid rgba(255,173,117,.2); border-radius: 12px; padding: 8px; background: rgba(0,0,0,.16); }
  .mvp-comment.child { margin-left: 22px; border-style: dashed; }
  .mvp-comment-meta { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 8px; }
  .mvp-comment-text { margin-top: 4px; white-space: pre-wrap; }
  .mvp-comment-note { margin-top: 6px; padding: 6px 8px; border-radius: 10px; background: rgba(255,255,255,.08); font-size: 12px; }
  .mvp-note-line { margin-top: 4px; font-size: 12px; color: rgba(255,255,255,.82); }
  .mvp-reply-chips { margin-top: 6px; display: flex; gap: 6px; flex-wrap: wrap; }
  .mvp-mini { border: 1px solid var(--line); border-radius: 999px; background: rgba(255,255,255,.06); color: var(--text); padding: 5px 8px; cursor: pointer; font-size: 11px; }
  .mvp-comment-form { margin-top: 8px; display: grid; grid-template-columns: 1fr auto auto; gap: 6px; }
  .mvp-comment-input { border: 1px solid var(--line); border-radius: 10px; background: rgba(255,255,255,.07); color: var(--text); padding: 8px; }
  .mvp-voice-row { 
    display: flex; 
    align-items: center; 
    flex-wrap: wrap; 
    gap: 8px; 
    margin-top: 8px;
    padding: 10px;
    background: rgba(255, 154, 61, 0.08);
    border-radius: 12px;
    border: 1px solid rgba(255, 154, 61, 0.2);
  }
  .mvp-voice-btn {
    border: 1px solid var(--brand2, #ff7a1f);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255, 154, 61, 0.25), rgba(255, 106, 0, 0.15));
    color: var(--text);
    padding: 8px 14px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 800;
    transition: all .2s ease;
    box-shadow: 0 0 15px rgba(255, 106, 0, 0.2);
  }
  .mvp-voice-btn:hover {
    background: linear-gradient(135deg, rgba(255, 154, 61, 0.35), rgba(255, 106, 0, 0.25));
    box-shadow: 0 0 25px rgba(255, 106, 0, 0.4);
    transform: scale(1.05);
  }
  .mvp-voice-btn.recording {
    animation: voiceRecordingPulse 1s ease-in-out infinite;
    background: linear-gradient(135deg, rgba(255, 50, 50, 0.35), rgba(255, 100, 0, 0.25));
    box-shadow: 0 0 25px rgba(255, 50, 50, 0.6);
  }
  @keyframes voiceRecordingPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  .mvp-voice-input { font-size: 11px; color: var(--text); }
  .mvp-voice-audio { 
    width: 100%; 
    margin-top: 8px;
    border-radius: 10px;
    background: rgba(255, 154, 61, 0.1);
    padding: 8px;
  }
  .mvp-voice-audio::-webkit-media-controls-panel {
    background: rgba(255, 154, 61, 0.15);
  }
  .mvp-voice-audio::-webkit-media-controls-play-button {
    filter: brightness(1.2);
  }
  .mvp-voice-waveform {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 40px;
    padding: 8px;
    background: rgba(255, 154, 61, 0.08);
    border-radius: 10px;
    flex: 1;
  }
  .mvp-voice-bar {
    width: 3px;
    background: linear-gradient(180deg, var(--brand2, #ff7a1f), var(--brand1, #ff9a3d));
    border-radius: 2px;
    animation: voiceWaveBar .5s ease-in-out infinite;
  }
  @keyframes voiceWaveBar {
    0%, 100% { height: 4px; opacity: 0.4; }
    50% { height: 24px; opacity: 1; }
  }
  .mvp-undo {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 10px;
    margin-left: 6px;
    background: rgba(255,255,255,.08);
    color: var(--text);
    cursor: pointer;
    font-size: 11px;
    font-weight: 700;
  }
  .gif-panel {
    border: 1px dashed var(--line);
    border-radius: 12px;
    padding: 10px;
    background: rgba(0,0,0,.18);
  }
  @media (max-width: 880px) {
    .mvp-row { grid-template-columns: 1fr; }
    .mvp-meta-row { grid-template-columns: 1fr; }
    .mvp-comment-form { grid-template-columns: 1fr; }
  }
</style>

<div class="feed-app">
  <header class="feed-topbar vf-topbar" role="navigation" aria-label="VybeFlow">
    <div class="vf-left">
      <a class="vf-brand" href="{{ url_for('feed') }}">
        <img
          class="vf-logo-img"
          src="{{ url_for('VFlogo_clean.png') }}"
          alt="VybeFlow logo"
        />
        <span>vybeflow</span>
      </a>

      <div class="vf-search" role="search">
        <span class="vf-ico" aria-hidden="true">вМХ</span>
        <input class="feed-search" type="search" placeholder="Search VybeFlow" aria-label="Search VybeFlow" />
      </div>
    </div>

    <div class="topbar-tools">
      <label class="retro-switch" for="retro-toggle">
        2011 Mode
        <input id="retro-toggle" type="checkbox" />
      </label>

      <div class="feed-icons">
      <a class="icon-btn" href="{{ url_for('feed') }}" title="Home">вМВ</a>
      <a class="icon-btn" href="{{ url_for('search') }}" title="Explore">вМХ</a>
      <a class="icon-btn" href="{{ url_for('create_picker') }}" title="Create">пЉЛ</a>
      <a class="icon-btn" href="{{ url_for('messenger') }}" title="Messenger">рЯТђ{% if notification_counts.messages %}<span class="icon-badge">{{ notification_counts.messages }}</span>{% endif %}</a>
      <a class="icon-btn" href="{{ url_for('live_hub') }}" title="Live">рЯУ°{% if notification_counts.live_invites %}<span class="icon-badge">{{ notification_counts.live_invites }}</span>{% endif %}</a>
      <a class="icon-btn" href="{{ url_for('account') }}" title="Account">вЧЙ</a>
      <a class="icon-btn" href="{{ url_for('settings') }}" title="Settings">вЪЩ</a>
      <a class="icon-btn" href="{{ url_for('logout') }}" title="Logout">вЖ©</a>
      </div>
    </div>
  </header>

  <div class="feed-grid">
    <aside class="left-panel panel">
      <div class="section-title">You</div>
      <a class="menu-item" href="{{ url_for('account') }}">
        <img src="{{ current_user.avatar_url }}" alt="avatar" />
        <div>
          <div style="font-weight:800; line-height:1.1;">{{ current_user.username }}</div>
          <div style="color: var(--muted); font-size: 13px;">@{{ current_user.username }}</div>
        </div>
      </a>

      <div class="section-title">Shortcuts</div>
      <a class="menu-item" href="{{ url_for('feed') }}">рЯП† Home</a>
      <a class="menu-item" href="{{ url_for('search') }}">вЬ® Explore</a>
      <a class="menu-item" href="{{ url_for('create_picker') }}">рЯОђ Create</a>
      <a class="menu-item" href="{{ url_for('logout') }}">рЯЪ™ Logout</a>

      <div class="mini-card">
        <div class="section-title" style="margin:0 0 8px;">Your Vybes</div>
        <a class="trend-chip" href="{{ url_for('search') }}">рЯФ• Trap</a>
        <a class="trend-chip" href="{{ url_for('search') }}">рЯОІ R&B</a>
        <a class="trend-chip" href="{{ url_for('search') }}">рЯПА Sports</a>
        <a class="trend-chip" href="{{ url_for('search') }}">рЯТЄ Hustle</a>
      </div>
    </aside>

    <main class="center-panel">
      <section class="feed-composer panel">
        <div class="composer-top">
          <img class="avatar" src="{{ current_user.avatar_url }}" alt="avatar" />
          <a class="composer-box" id="open-creator-main" href="{{ url_for('upload') }}?mode=post">
            WhatвАЩs the vybe today, {{ current_user.username }}?
          </a>
        </div>

        <div class="composer-actions">
          <a class="chip" href="{{ url_for('upload') }}?mode=post">рЯУЭ Post</a>
          <a class="chip" href="{{ url_for('upload') }}?mode=photo">рЯУЄ Photo</a>
          <a class="chip" href="{{ url_for('upload') }}?mode=reel">рЯО• Reel</a>
          <a class="chip" href="{{ url_for('upload') }}?mode=live">рЯФі Live</a>
        </div>
      </section>

      <section class="panel game-card">
        <h3>Feed Game: Guess 1-10</h3>
        <div class="game-hud"><span id="game-hint">Pick a number</span><span id="game-score">Score: 0</span></div>
        <div class="lab-actions">
          <button type="button" class="lab-btn game-guess" data-n="1">1</button>
          <button type="button" class="lab-btn game-guess" data-n="2">2</button>
          <button type="button" class="lab-btn game-guess" data-n="3">3</button>
          <button type="button" class="lab-btn game-guess" data-n="4">4</button>
          <button type="button" class="lab-btn game-guess" data-n="5">5</button>
        </div>
      </section>

      <section class="panel ai-card">
        <h3>Vybe AI Feed Assistant</h3>
        <div id="ai-log" class="ai-log">AI ready. Ask for post ideas, hashtags, or challenge captions.</div>
        <input id="ai-input" class="lab-input" type="text" placeholder="Ask AI anything for your feed..." />
        <div class="lab-actions">
          <button type="button" id="ai-send" class="lab-btn">Ask AI</button>
        </div>
      </section>

      <!-- ===== Reels Rail (IG-ish, but VybeFlow flex) ===== -->
      <section class="panel reels-rail" aria-label="Reels">
        <div class="reels-head">
          <div>
            <div class="reels-title">Reels</div>
            <div class="reels-sub">Tap to flex вАҐ Hover to preview вАҐ Drop heat рЯФ•</div>
          </div>

          <div class="reels-actions">
            <button type="button" class="reels-chip" id="reels-for-you">вЬ® For You</button>
            <button type="button" class="reels-chip" id="reels-chaos">рЯО≤ Chaos</button>
            <a class="reels-chip" href="{{ url_for('create_reel') }}">пЉЛ Create</a>
          </div>
        </div>

        <div class="reels-row" id="reels-row">
          {# Example: if you have reels list from backend, loop them #}
          {# Expected fields: r.id, r.cover_url, r.video_url, r.user.avatar_url, r.user.username, r.duration_label #}

          {% if reels %}
            {% for r in reels %}
            <button
              type="button"
              class="reel-card"
              data-reel-id="{{ r.id }}"
              data-video="{{ r.video_url }}"
              data-cover="{{ r.cover_url }}"
              data-user="{{ r.user.username }}"
              data-avatar="{{ r.user.avatar_url }}"
              data-duration="{{ r.duration_label or '' }}"
              data-likes="{{ r.like_count or 0 }}"
              data-comments="{{ r.comment_count or 0 }}"
              data-views="{{ r.view_count or 0 }}"
              data-created-at="{{ r.created_at or '' }}"
            >
              <div class="reel-heat">рЯФ• HOT</div>
              <div class="reel-media" style="background-image:url('{{ r.cover_url }}')"></div>

              <div class="reel-glass-top">
                <div class="reel-badges">
                  <span class="reel-pill">REEL</span>
                  {% if r.duration_label %}<span class="reel-pill ghost">{{ r.duration_label }}</span>{% endif %}
                </div>
                <div class="reel-play">вЦґ</div>
              </div>

              <div class="reel-hover-overlay" aria-label="Reel quick actions">
                <button type="button" class="reel-overlay-btn reel-like-btn" data-action="like">рЯФ• <span>{{ r.like_count or 0 }}</span></button>
                <button type="button" class="reel-overlay-btn reel-comment-btn" data-action="comment">рЯТђ <span>{{ r.comment_count or 0 }}</span></button>
              </div>

              <div class="reel-glass-bot">
                <img class="reel-avatar" src="{{ r.user.avatar_url }}" alt="avatar">
                <div class="reel-user">@{{ r.user.username }}</div>
                <div class="reel-flex" title="Flex meter">
                  <span class="reel-flame">рЯФ•</span>
                  <span class="reel-flex-num">0</span>
                </div>
              </div>
            </button>
            {% endfor %}
          {% else %}
            <div style="padding:10px;color:var(--muted);">No reels yet вАФ be the first to drop one.</div>
          {% endif %}
        </div>
      </section>

      <!-- ===== Fullscreen Reel Viewer ===== -->
      <div class="reel-viewer" id="reel-viewer" hidden>
        <button type="button" class="reel-view-close" id="reel-view-close" aria-label="Close">вЬХ</button>

        <div class="reel-view-stage">
          <video id="reel-view-video" class="reel-view-video" playsinline muted loop></video>
          <div class="reel-view-hint">Swipe or scroll up/down</div>

          <div class="reel-view-hud">
            <div class="reel-view-user">
              <img id="reel-view-avatar" class="reel-view-avatar" alt="avatar">
              <div>
                <div id="reel-view-handle" class="reel-view-handle">@user</div>
                <div class="reel-view-sub">VybeFlow Reel</div>
              </div>
            </div>

            <div class="reel-view-actions">
              <button type="button" class="rv-btn" id="rv-like">рЯФ•</button>
              <button type="button" class="rv-btn" id="rv-share">рЯЪА</button>
              <button type="button" class="rv-btn" id="rv-sound">рЯФЗ</button>
            </div>
          </div>
        </div>
      </div>

      <section class="story-row panel" aria-label="Stories">
        <a href="{{ url_for('create_story') }}" class="story-card story-create">
          <div class="story-media">пЉЛ</div><p>Create story</p>
        </a>
        {% if stories %}
          {% for story in stories %}
          <div class="story-card">
            <button
              type="button"
              class="story-open"
              data-story-title="{{ story.title }}"
              data-story-user="@{{ story.username }}"
              data-story-caption="{{ story.caption }}"
              data-story-location="{{ story.location }}"
              data-story-mentions="{{ story.mentions|join(', ') }}"
              data-story-effects="{{ story.effects|join(', ') }}"
              data-story-graphics="{{ story.graphics|join(', ') }}"
              data-story-music="{{ story.music_track }}"
              data-story-image="{{ story.image }}"
              data-story-audio="{{ story.music_file_url or story.music_preview_url }}"
            >
                <div class="story-media" style="background-image:url('{{ story.image }}'); background-size:cover; background-position:center;"></div>
              <p>{{ story.title }}</p>
            </button>

            {% if story.music_file_url or story.music_preview_url %}
              <div class="story-inline-music">
                <div class="story-inline-title">вЩЂ {{ story.music_track or "Music" }}</div>
                <audio class="story-inline-audio" controls preload="metadata">
                  <source src="{{ story.music_file_url or story.music_preview_url }}">
                </audio>
              </div>
            {% endif %}
          </div>
          {% endfor %}
        {% endif %}
      </section>

      <section class="panel mvp-post-panel" aria-label="MVP Social Feed">
        <h3 style="margin:0;">Create Post</h3>
        <textarea id="mvp-post-caption" class="mvp-input" rows="3" placeholder="Vybe your way..."></textarea>
        <div class="mvp-pill-row">
          <button id="toggle-location" class="mvp-pill" type="button">рЯУН Location</button>
          <button id="toggle-emojis" class="mvp-pill" type="button">рЯШД Emoji</button>
          <button id="toggle-gifs" class="mvp-pill" type="button">GIF</button>
        </div>
        <div id="emoji-panel" class="emoji-panel" hidden>
          <div class="emoji-toolbar">
            <button id="emoji-tab" class="emoji-tab active" type="button">Emojis</button>
            <button id="sticker-tab" class="emoji-tab" type="button">Stickers</button>
          </div>
          <div id="emoji-row" class="emoji-row"></div>
          <div id="sticker-grid" class="sticker-grid" hidden></div>
          <div id="emoji-stage" class="emoji-stage" aria-label="Emoji stage"></div>
          <div class="emoji-stage-note">Tap an emoji for a pop, or drag onto the stage.</div>
        </div>
        <div id="gif-panel" class="gif-panel" hidden>
          <input id="gif-search" class="mvp-input" type="text" placeholder="Search GIFs..." />
          <div id="gif-grid" class="gif-grid"></div>
        </div>
        <div class="mvp-meta-row">
          <div>
            <span class="mvp-label">Who can see this</span>
            <select id="mvp-post-visibility" class="mvp-select">
              <option value="Public">Public</option>
              <option value="Friends">Friends</option>
              <option value="Private">Only me</option>
            </select>
          </div>
          <div>
            <span class="mvp-label">Share to</span>
            <div class="mvp-share-row">
              <label class="mvp-share-chip"><input id="share-ig" type="checkbox" /> IG</label>
              <label class="mvp-share-chip"><input id="share-tt" type="checkbox" /> TikTok</label>
              <label class="mvp-share-chip"><input id="share-x" type="checkbox" /> X</label>
            </div>
          </div>
        </div>
        <div class="mvp-row">
          <select id="mvp-post-bg" class="mvp-select">
            <option value="default">Background: Default</option>
            <option value="sunset">Background: Sunset</option>
            <option value="neon">Background: Neon</option>
            <option value="glass">Background: Glass</option>
          </select>
          <input id="mvp-post-bg-custom" class="mvp-input" type="color" value="#ff8a3c" title="Pick any background color" />
          <input id="mvp-post-media" class="mvp-input" type="file" accept="image/*,video/*" />
          <button id="mvp-post-create" class="mvp-btn" type="button">Publish</button>
        </div>
        <div id="mvp-post-feedback" class="mvp-feedback"></div>
        <div id="mvp-posts-list" class="mvp-posts"></div>
        <span class="mvp-feedback" style="display:none;">No comments yet</span>
      </section>

      {% for post in posts %}
      {% set post_user = post.user if post.user is defined and post.user else current_user %}
      <article class="post-card panel">
        <div class="post-head">
          <div class="post-user">
            <img class="avatar" src="{{ post_user.avatar_url }}" alt="avatar" />
            <div class="meta">
              <div class="name">{{ post_user.username }}</div>
              <div class="sub">
                <span>{{ post.created_at_display or 'Just now' }}</span>
                <span>вАҐ</span>
                <span>рЯМР {{ post.visibility or 'Public' }}</span>
              </div>
            </div>
          </div>
          <button class="post-menu" type="button" title="More">вЛѓ</button>
        </div>

        {% if post.caption %}
          <div class="post-body">{{ post.caption }}</div>
        {% endif %}


        {% if post.media_path %}
          {% if post.media_type == "video" %}
            <div class="post-media">
              <video controls playsinline preload="metadata" style="width:100%;height:auto;border-radius:14px;">
                <source src="{{ url_for('static', filename=post.media_path) }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            </div>
          {% else %}
            <div class="post-media">
              <img src="{{ url_for('static', filename=post.media_path) }}" style="width:100%;height:auto;border-radius:14px;" />
            </div>
          {% endif %}
        {% elif post.gif_url %}
          <div class="post-media">
            <img src="{{ post.gif_url }}" style="width:100%;height:auto;border-radius:14px;" />
          </div>
        {% endif %}

        <div class="post-stats">
          <div>рЯФ• {{ post.like_count or 0 }} likes</div>
          <div>{{ post.comment_count or 0 }} comments</div>
        </div>

        <div class="post-actions">
          <button class="gloss-btn" type="button">рЯФ• Like</button>
          <button class="gloss-btn" type="button">рЯТђ Comment</button>
          <button class="gloss-btn" type="button">вЖЧ Share</button>
        </div>
      </article>
      {% endfor %}

      {% if not posts %}
      <article class="post-card panel">
        <div class="post-body">No posts yet. Create one from the composer above.</div>
      </article>
      {% endif %}
    </main>

    <aside class="right-panel panel">
      <div class="section-title">Quick Actions</div>
      <a class="menu-item" href="{{ url_for('account') }}">рЯС§ View Account</a>
      <a class="menu-item" href="{{ url_for('upload') }}">вђЖпЄП Upload Media</a>
      <a class="menu-item" href="{{ url_for('messenger') }}">рЯТђ Messenger{% if notification_counts.messages %} ({{ notification_counts.messages }}){% endif %}</a>
      <a class="menu-item" href="{{ url_for('live_hub') }}">рЯУ° Live Hub{% if notification_counts.live_invites %} ({{ notification_counts.live_invites }} invites){% endif %}</a>
      <a class="menu-item" href="{{ url_for('search') }}">рЯФО Search</a>
      <a class="menu-item" href="{{ url_for('support') }}">рЯЖШ Help &amp; Support</a>
      <a class="menu-item" href="{{ url_for('settings') }}">вЪЩ Settings</a>
      <a class="menu-item" href="{{ url_for('logout') }}">рЯЪ™ Sign Out</a>

      <div class="mini-card">
        <div class="section-title" style="margin:0 0 8px;">Trending on VybeFlow</div>
        <a class="trend-chip" href="{{ url_for('search') }}">#OpenVerse</a>
        <a class="trend-chip" href="{{ url_for('search') }}">#RoastMe</a>
        <a class="trend-chip" href="{{ url_for('search') }}">#BeatTok</a>
        <a class="trend-chip" href="{{ url_for('search') }}">#MeetCute</a>
      </div>

      <!-- People to Follow section removed -->
    </aside>
  </div>
</div>
<div id="vf-create" class="vf-create" hidden>
  <div class="vf-create-top">
    <button type="button" class="vf-x" id="vf-create-close" aria-label="Close">√Ч</button>
    <div class="vf-title" id="vf-create-title">New reel</div>
    <button type="button" class="vf-gear" title="Settings">вЪЩ</button>
  </div>

  <div class="vf-create-actions">
    <button type="button" class="vf-pill">Drafts</button>
    <button type="button" class="vf-pill">Templates</button>
  </div>

  <div class="vf-create-row">
    <div class="vf-row-left">
      <div class="vf-row-label">Recents</div>
      <div class="vf-row-caret">вЦЊ</div>
    </div>
    <button type="button" class="vf-select">Select</button>
  </div>

  <div class="vf-grid">
    <button type="button" class="vf-tile vf-camera" id="vf-open-camera">
      <div class="vf-cam-icon">рЯУЈ</div>
    </button>

    {% for m in recent_media %}
      <button
        type="button"
        class="vf-tile"
        data-url="{{ m.url }}"
        data-type="{{ m.type }}"
      >
        {% if m.type == 'video' %}
          <video src="{{ m.url }}" muted playsinline preload="metadata"></video>
          <div class="vf-badge">вЦґ</div>
        {% else %}
          <img src="{{ m.url }}" alt="recent media">
        {% endif %}
      </button>
    {% endfor %}

    {% if not recent_media %}
      <div class="vf-empty">
        No recents yet. Upload something and itвАЩll show here.
      </div>
    {% endif %}
  </div>

  <div class="vf-tabs">
    <button type="button" class="vf-tab" data-mode="post">POST</button>
    <button type="button" class="vf-tab" data-mode="story">STORY</button>
    <button type="button" class="vf-tab active" data-mode="reel">REEL</button>
    <button type="button" class="vf-tab" data-mode="live">LIVE</button>
  </div>

  <input id="vf-file-post" type="file" accept="image/*,video/*" hidden>
  <input id="vf-file-story" type="file" accept="image/*,video/*" hidden>
  <input id="vf-file-reel" type="file" accept="video/*" hidden>
</div>
<div id="story-modal-wrap" class="story-modal-wrap" hidden>
  <button type="button" id="story-close" class="story-close" aria-label="Close story">√Ч</button>
  <div class="story-modal">
    <div class="story-progress"><span id="story-progress-bar"></span></div>
    <div id="story-modal-media" class="story-modal-media"></div>
    <div class="story-modal-meta">
      <h4 id="story-title"></h4>
      <p id="story-caption"></p>
      <div id="story-modal-audio-wrap" class="story-modal-audio-wrap" style="display:none;">
        <div style="font-weight:900;color:rgba(255,255,255,.85);">вЩЂ Story audio</div>
        <audio id="story-modal-audio" class="story-modal-audio" controls preload="metadata"></audio>
      </div>
    </div>
  </div>
</div>
<script>
  (function () {
    function applyRetroState(enabled) {
      const isOn = !!enabled;
      document.body.classList.toggle('retro-2011', isOn);
      document.body.setAttribute('data-retro', isOn ? '1' : '0');
      try {
        window.localStorage.setItem('vybe_feed_retro_2011', isOn ? '1' : '0');
      } catch (error) {
      }
    }


    const retroToggle = document.getElementById('retro-toggle');
    if (retroToggle) {
      const sharedRetro = window.VybeTheme && typeof window.VybeTheme.loadRetro === 'function'
        ? window.VybeTheme.loadRetro()
        : (window.localStorage.getItem('vybe_feed_retro_2011') === '1');

      retroToggle.checked = !!sharedRetro;
      applyRetroState(retroToggle.checked);

      retroToggle.addEventListener('change', function () {
        const enabled = retroToggle.checked;
        if (window.VybeTheme && typeof window.VybeTheme.setRetro === 'function') {
          window.VybeTheme.setRetro(enabled);
        }
        applyRetroState(enabled);
        // Force UI update for all retro-2011 styles and elements
        setTimeout(function() {
          document.body.offsetHeight; // force reflow
        }, 10);
      });
    }

    const modal = document.getElementById('story-modal-wrap');
    const closeStory = document.getElementById('story-close');
    const title = document.getElementById('story-title');
    const caption = document.getElementById('story-caption');
    const modalMedia = document.getElementById('story-modal-media');
    const modalAudioWrap = document.getElementById('story-modal-audio-wrap');
    const modalAudio = document.getElementById('story-modal-audio');
    const progressBar = document.getElementById('story-progress-bar');
    let storyTimer = null;

    function closeModal() {
      if (!modal) return;
      modal.hidden = true;
      document.body.style.overflow = '';
      if (storyTimer) {
        clearTimeout(storyTimer);
        storyTimer = null;
      }
      if (modalAudio) {
        modalAudio.pause();
        modalAudio.removeAttribute('src');
        modalAudio.load();
      }
      if (modalAudioWrap) {
        modalAudioWrap.style.display = 'none';
      }
    }

    document.querySelectorAll('.story-open').forEach(function (card) {
      card.addEventListener('click', function () {
        if (!modal) return;
        title.textContent = card.dataset.storyTitle + ' ' + card.dataset.storyUser;
        const captionParts = [card.dataset.storyCaption || ''];
        if (card.dataset.storyLocation) captionParts.push('рЯУН ' + card.dataset.storyLocation);
        if (card.dataset.storyMentions) captionParts.push('рЯС• ' + card.dataset.storyMentions);
        if (card.dataset.storyEffects) captionParts.push('вЬ® ' + card.dataset.storyEffects);
        if (card.dataset.storyGraphics) captionParts.push('рЯЦЉ ' + card.dataset.storyGraphics);
        if (card.dataset.storyMusic) captionParts.push('рЯОµ ' + card.dataset.storyMusic);
        caption.textContent = captionParts.filter(Boolean).join(' вАҐ ');

        if (modalMedia) {
          const mediaUrl = card.dataset.storyImage || '';
          if (mediaUrl) {
            if (/\.(mp4|mov|webm|m4v)(\?|#|$)/i.test(mediaUrl)) {
              modalMedia.innerHTML = '<video src="' + mediaUrl + '" controls autoplay muted playsinline></video>';
            } else {
              modalMedia.innerHTML = '<img src="' + mediaUrl + '" alt="Story media" />';
            }
          } else {
            modalMedia.innerHTML = '';
          }
        }

        const audioUrl = card.dataset.storyAudio || '';
        if (modalAudioWrap && modalAudio) {
          if (audioUrl) {
            modalAudioWrap.style.display = 'block';
            modalAudio.src = audioUrl;
            modalAudio.load();
          } else {
            modalAudioWrap.style.display = 'none';
            modalAudio.removeAttribute('src');
            modalAudio.load();
          }
        }

        modal.hidden = false;
        document.body.style.overflow = 'hidden';

        progressBar.style.transition = 'none';
        progressBar.style.width = '0';
        requestAnimationFrame(function () {
          progressBar.style.transition = 'width 4s linear';
          progressBar.style.width = '100%';
        });

        if (storyTimer) clearTimeout(storyTimer);
        storyTimer = setTimeout(closeModal, 4000);
      });
    });

    document.querySelectorAll('.story-inline-audio').forEach(function (audioEl) {
      ['click', 'pointerdown', 'touchstart'].forEach(function (eventName) {
        audioEl.addEventListener(eventName, function (event) {
          event.stopPropagation();
        });
      });
    });

    if (closeStory) closeStory.addEventListener('click', closeModal);
    if (modal) {
      modal.addEventListener('click', function (event) {
        if (event.target === modal) closeModal();
      });
    }

    async function moderateDraft(text, mediaName) {
      const response = await fetch("{{ url_for('moderate_content_api') }}", {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: text || '', media_name: mediaName || '' })
      });

      let payload = {};
      try {
        payload = await response.json();
      } catch (error) {
        payload = { ok: false, reason: 'moderation_unavailable' };
      }

      if (payload.banned) {
        alert(payload.stamp || 'YOU GOT BANNED');
        window.location.href = "{{ url_for('banned') }}";
        return { allowed: false, banned: true, payload: payload };
      }

      if (!payload.ok || payload.removed) {
        const warningLine = payload.warnings ? (' Warning ' + payload.warnings + '/3.') : '';
        alert('Content removed by AI moderation.' + warningLine);
        return { allowed: false, banned: false, payload: payload };
      }

      return { allowed: true, banned: false, payload: payload };
    }

    const buttons = document.querySelectorAll('.feed-action');
    buttons.forEach(function (button) {
      button.addEventListener('click', async function () {
        const action = button.dataset.action;
        if (action === 'like') {
          button.textContent = button.textContent.includes('Liked') ? 'рЯФ• Like' : 'рЯФ• Liked';
          return;
        }
        if (action === 'comment') {
          const rawComment = prompt('Write a comment:');
          if (!rawComment || !rawComment.trim()) return;
          const result = await moderateDraft(rawComment.trim(), '');
          if (!result.allowed) return;
          alert('Comment posted.');
          return;
        }
        if (action === 'share') {
          const url = window.location.href;
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(url).then(function () {
              button.textContent = 'вЬЕ Copied';
              setTimeout(function () { button.textContent = 'рЯЪА Share'; }, 1000);
            });
          }
        }
      });
    });

