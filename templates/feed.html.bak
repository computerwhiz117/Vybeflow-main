    ];
    const audioCtx = window.AudioContext ? new AudioContext() : (window.webkitAudioContext ? new webkitAudioContext() : null);
    const emojiSoundFiles = {
      'рЯФ•': 'fire-pop.mp3',
      'рЯШВ': 'laugh-pop.mp3',
      'рЯТЬ': 'love-bloop.mp3',
      'рЯОµ': 'tiny-jingle.mp3',
